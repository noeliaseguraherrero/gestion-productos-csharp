@page
@model Practica1.Pages.Productos.DetalleModel
@{
    ViewData["Title"] = "Detalle del Producto - BecariosBD";
}

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

<style>
    /* 1. CONFIGURACIÓN DEL CUERPO (ESTILO LIGHT) */
    nav, .navbar, footer, header:not(.header-home) {
        display: none !important;
    }

    body {
        margin: 0;
        padding: 0;
        width: 100%;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        font-family: 'Inter', sans-serif;
        background-color: #ffffff;
        color: #333;
    }

    /* 2. CONTENEDOR PRINCIPAL (MISMA POSICIÓN) */
    .main-container {
        display: flex;
        justify-content: center;
        align-items: flex-start;
        width: 100%;
        padding: 60px 20px;
        box-sizing: border-box;
    }

    /* 3. TARJETA BLANCA (ANCHO 1100px) */
    .glass-card {
        background: #ffffff;
        padding: 50px;
        border-radius: 40px;
        width: 100%;
        max-width: 1100px;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.08);
        border: 1px solid #f0f0f0;
    }

    h1 {
        margin: 0 0 40px 0;
        text-align: center;
        font-weight: 800;
        letter-spacing: -1.5px;
        font-size: 2.8rem;
        text-transform: uppercase;
        color: #1a1a1a;
    }

    /* 4. ÁREA DE INFORMACIÓN */
    .info-content {
        max-width: 600px;
        margin: 0 auto;
        background-color: #fafafa;
        padding: 40px;
        border-radius: 25px;
        border: 1px solid #eee;
    }

    .info-item {
        margin-bottom: 25px;
        border-bottom: 1px solid #eee;
        padding-bottom: 15px;
    }

        .info-item:last-child {
            border-bottom: none;
            margin-bottom: 0;
        }

    .info-label {
        display: block;
        font-size: 0.8rem;
        color: darkred;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 2px;
        margin-bottom: 8px;
    }

    .info-value {
        font-size: 1.2rem;
        font-weight: 600;
        color: #1a1a1a;
    }

    /* 5. BOTONES */
    .btn-container {
        max-width: 600px;
        margin: 40px auto 0 auto;
        display: flex;
    }

    .btn-cyber {
        flex: 1;
        padding: 18px;
        border-radius: 15px;
        background: #ffffff;
        color: #666;
        border: 1px solid #ddd;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        cursor: pointer;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        text-decoration: none;
    }

        .btn-cyber:hover {
            background: #f5f5f5;
            color: #1a1a1a;
            border-color: #ccc;
            transform: translateY(-3px);
        }
</style>

<div class="main-container">
    <div class="glass-card">
        <h1>Detalle del Producto</h1>

        <div class="info-content">
            <div class="info-item">
                <span class="info-label">Nombre del Producto</span>
                <span class="info-value">@Model.Producto.Nombre</span>
            </div>

            <div class="info-item">
                <span class="info-label">Precio Unitario</span>
                <span class="info-value">@Model.Producto.Precio.ToString("C")</span>
            </div>

            <div class="info-item">
                <span class="info-label">Stock Actual</span>
                <span class="info-value" style="color: @(Model.Producto.Stock < 5 ? "#d32f2f" : "#1b5e20")">
                    @Model.Producto.Stock unidades
                </span>
            </div>

            <div class="info-item">
                <span class="info-label">Fecha de Registro</span>
                <span class="info-value">@Model.Producto.FechaCreacion.ToString("f")</span>
            </div>
        </div>

        <div class="btn-container">
            <a asp-page="./Inicio" class="btn-cyber">
                <i class="bi bi-arrow-left"></i> Volver al Inventario
            </a>
        </div>
    </div>
</div>