@page
@model Practica1.Pages.Productos.CrearModel
@{
    ViewData["Title"] = "Nuevo Producto - BecariosBD";
}

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

<style>
    nav, .navbar, footer, header:not(.header-home) {
        display: none !important;
    }

    body {
        margin: 0;
        padding: 0;
        width: 100%;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        font-family: 'Inter', sans-serif;
        background-color: #ffffff;
        color: #333;
    }

    .main-container {
        display: flex;
        justify-content: center;
        align-items: flex-start;
        width: 100%;
        padding: 40px 15px;
        box-sizing: border-box;
    }

    .glass-card {
        background: #ffffff;
        padding: 40px 35px;
        border-radius: 30px;
        width: 100%;
        max-width: 1100px;
        box-shadow: 0 20px 60px rgba(0,0,0,0.08);
        border: 1px solid #f0f0f0;
        box-sizing: border-box;
    }

    h1 {
        margin: 0 0 35px 0;
        text-align: center;
        font-weight: 800;
        letter-spacing: -1px;
        font-size: clamp(1.6rem, 4vw, 2.8rem);
        text-transform: uppercase;
        color: #1a1a1a;
    }

    .form-content {
        max-width: 600px;
        margin: 0 auto;
    }

    .form-group {
        margin-bottom: 22px;
    }

    label {
        display: block;
        margin-bottom: 8px;
        font-size: 0.78rem;
        color: darkred;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 2px;
    }

    input {
        width: 100%;
        padding: 16px 20px;
        border-radius: 13px;
        border: 2px solid #eee;
        box-sizing: border-box;
        background-color: #fafafa;
        color: #333;
        font-size: 1rem;
        outline: none;
        transition: all 0.3s ease;
    }

        input:hover, input:focus {
            background-color: #fff;
            border-color: #1b5e20;
            box-shadow: 0 5px 15px rgba(27,94,32,0.1);
        }

    .btn-container {
        display: flex;
        gap: 12px;
        margin-top: 35px;
        flex-wrap: wrap;
    }

    .btn-cyber {
        flex: 2;
        min-width: 140px;
        padding: 16px;
        border-radius: 13px;
        border: none;
        background: #1b5e20;
        color: white;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        cursor: pointer;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        text-decoration: none;
        box-shadow: 0 8px 20px rgba(27,94,32,0.15);
        font-family: 'Inter', sans-serif;
        font-size: 0.9rem;
    }

        .btn-cyber:hover {
            transform: translateY(-3px);
            background: #2e7d32;
            box-shadow: 0 12px 25px rgba(27,94,32,0.25);
        }

    .btn-back {
        flex: 1;
        min-width: 100px;
        background: #fff;
        color: #666;
        border: 1px solid #ddd;
        box-shadow: none;
    }

        .btn-back:hover {
            background: #f5f5f5;
            color: #333;
            border-color: #ccc;
        }

    .error-msg {
        color: #d32f2f;
        font-size: 0.82rem;
        font-weight: 600;
        margin-top: 5px;
        display: block;
    }

    @@media (max-width: 600px) {
        .glass-card

    {
        padding: 25px 15px;
        border-radius: 20px;
    }

    .main-container {
        padding: 20px 10px;
    }

    .btn-container {
        flex-direction: column;
    }

    .btn-cyber, .btn-back {
        flex: unset;
        width: 100%;
    }

    }
</style>

<div class="main-container">
    <div class="glass-card">
        <h1>Nuevo Producto</h1>
        <div class="form-content">
            <form method="POST">
                <div class="form-group">
                    <label asp-for="Producto.CodigoProducto">Código de Producto</label>
                    <input asp-for="Producto.CodigoProducto" placeholder="Ej. PROD-001" />
                    <span asp-validation-for="Producto.CodigoProducto" class="error-msg"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Producto.Nombre">Nombre del Producto</label>
                    <input asp-for="Producto.Nombre" placeholder="Ej. Monitor curvo 27&quot;" />
                    <span asp-validation-for="Producto.Nombre" class="error-msg"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Producto.Precio">Precio de Venta</label>
                    <input asp-for="Producto.Precio" placeholder="0.00" />
                    <span asp-validation-for="Producto.Precio" class="error-msg"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Producto.Stock">Stock en Almacén</label>
                    <input asp-for="Producto.Stock" placeholder="Cant. unidades" />
                    <span asp-validation-for="Producto.Stock" class="error-msg"></span>
                </div>
                <div class="btn-container">
                    <button type="submit" class="btn-cyber">
                        <i class="bi bi-plus-circle-fill"></i> Registrar
                    </button>
                    <a asp-page="./Inicio" class="btn-cyber btn-back">
                        <i class="bi bi-arrow-left"></i> Volver
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}