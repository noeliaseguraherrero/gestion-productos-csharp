@page
@model Practica1.Pages.Productos.EditarModel
@{
    ViewData["Title"] = "Editar - BecariosBD";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

<style>
    nav, .navbar, footer, header:not(.header-home) {
        display: none !important;
    }

    *, *::before, *::after {
        box-sizing: border-box;
    }

    html, body {
        overflow-x: hidden;
        max-width: 100%;
        margin: 0;
        padding: 0;
    }

    body {
        width: 100%;
        min-height: 100vh;
        font-family: 'Inter', sans-serif;
        background: linear-gradient(135deg, #f0f4f8 0%, #e8edf2 100%);
        color: #1a1a2e;
    }

    .app-layout {
        display: flex;
        min-height: 100vh;
        overflow-x: hidden;
    }

    .sidebar {
        width: 240px;
        min-height: 100vh;
        background: #0f172a;
        display: flex;
        flex-direction: column;
        padding: 30px 0;
        position: fixed;
        top: 0;
        left: 0;
        z-index: 200;
        transition: transform 0.3s ease;
    }

    .sidebar-logo {
        padding: 0 25px 30px 25px;
        border-bottom: 1px solid rgba(255,255,255,0.06);
        margin-bottom: 20px;
    }

        .sidebar-logo h2 {
            color: #fff;
            font-size: 1.1rem;
            font-weight: 800;
            margin: 0;
            letter-spacing: -0.5px;
            text-transform: uppercase;
        }

        .sidebar-logo span {
            color: #3b82f6;
        }

        .sidebar-logo p {
            color: #64748b;
            font-size: 0.72rem;
            margin: 4px 0 0 0;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

    .sidebar-section {
        padding: 0 15px;
        margin-bottom: 25px;
    }

    .sidebar-section-title {
        color: #475569;
        font-size: 0.65rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        padding: 0 10px;
        margin-bottom: 8px;
    }

    .sidebar-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 11px 12px;
        border-radius: 10px;
        color: #94a3b8;
        text-decoration: none;
        font-size: 0.88rem;
        font-weight: 500;
        transition: all 0.2s ease;
        margin-bottom: 3px;
        border: none;
        background: transparent;
        width: 100%;
    }

        .sidebar-item:hover {
            background: rgba(255,255,255,0.07);
            color: #fff;
        }

        .sidebar-item.active {
            background: linear-gradient(135deg, #1d4ed8, #3b82f6);
            color: #fff;
            box-shadow: 0 4px 15px rgba(59,130,246,0.3);
        }

        .sidebar-item i {
            font-size: 1rem;
            width: 20px;
            text-align: center;
            flex-shrink: 0;
        }

    .sidebar-bottom {
        margin-top: auto;
        padding: 20px 15px;
        border-top: 1px solid rgba(255,255,255,0.06);
    }

    .user-info {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px;
        border-radius: 10px;
        background: rgba(255,255,255,0.05);
        margin-bottom: 10px;
    }

    .user-avatar {
        width: 36px;
        height: 36px;
        border-radius: 10px;
        background: linear-gradient(135deg, #1d4ed8, #3b82f6);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: 700;
        font-size: 0.9rem;
        flex-shrink: 0;
    }

    .user-details {
        overflow: hidden;
    }

    .user-name {
        color: #e2e8f0;
        font-size: 0.82rem;
        font-weight: 600;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .user-role {
        color: #64748b;
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .btn-logout-sidebar {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 10px 12px;
        border-radius: 10px;
        color: #ef4444;
        background: rgba(239,68,68,0.08);
        border: 1px solid rgba(239,68,68,0.15);
        text-decoration: none;
        font-size: 0.82rem;
        font-weight: 600;
        transition: all 0.2s ease;
        width: 100%;
        justify-content: center;
    }

        .btn-logout-sidebar:hover {
            background: #ef4444;
            color: white;
        }

    .main-wrapper {
        margin-left: 240px;
        flex: 1;
        padding: 30px;
        min-height: 100vh;
        min-width: 0;
        width: calc(100% - 240px);
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .topbar {
        width: 100%;
        max-width: 800px;
        margin-bottom: 24px;
    }

    .topbar-title h1 {
        font-size: 1.6rem;
        font-weight: 800;
        color: #0f172a;
        margin: 0;
        letter-spacing: -0.5px;
    }

    .topbar-title p {
        color: #64748b;
        font-size: 0.85rem;
        margin: 4px 0 0 0;
    }

    .form-card {
        background: #fff;
        border-radius: 20px;
        border: 1px solid #f1f5f9;
        box-shadow: 0 2px 15px rgba(0,0,0,0.04);
        width: 100%;
        max-width: 800px;
        overflow: hidden;
    }

    .form-header {
        padding: 24px 28px;
        border-bottom: 1px solid #f1f5f9;
    }

        .form-header h2 {
            margin: 0;
            font-size: 1rem;
            font-weight: 700;
            color: #0f172a;
        }

        .form-header p {
            margin: 4px 0 0 0;
            color: #64748b;
            font-size: 0.85rem;
        }

    .form-body {
        padding: 28px;
    }

    .form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
    }

    .form-group {
        display: flex;
        flex-direction: column;
    }

    label {
        display: block;
        font-size: 0.72rem;
        font-weight: 700;
        color: #94a3b8;
        text-transform: uppercase;
        letter-spacing: 0.8px;
        margin-bottom: 8px;
    }

    input[type="text"], input[type="number"] {
        width: 100%;
        padding: 11px 14px;
        border-radius: 10px;
        border: 1px solid #e2e8f0;
        background: #f8fafc;
        font-family: 'Inter', sans-serif;
        font-size: 0.88rem;
        outline: none;
        transition: all 0.3s ease;
        color: #0f172a;
    }

        input[type="text"]:focus, input[type="number"]:focus {
            background: #fff;
            border-color: #3b82f6;
            box-shadow: 0 0 0 3px rgba(59,130,246,0.1);
        }

    .error-msg {
        color: #ef4444;
        font-size: 0.75rem;
        font-weight: 600;
        margin-top: 5px;
        display: block;
    }

    .form-footer {
        padding: 20px 28px;
        background: #f8fafc;
        border-top: 1px solid #f1f5f9;
        display: flex;
        justify-content: flex-end;
        gap: 10px;
    }

    .btn-action {
        padding: 10px 22px;
        border-radius: 10px;
        font-weight: 700;
        font-size: 0.88rem;
        border: none;
        cursor: pointer;
        transition: all 0.2s ease;
        display: inline-flex;
        align-items: center;
        gap: 7px;
        text-decoration: none;
    }

    .btn-save {
        background: linear-gradient(135deg, #1d4ed8, #3b82f6);
        color: white;
        box-shadow: 0 4px 15px rgba(59,130,246,0.3);
    }

        .btn-save:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(59,130,246,0.4);
            color: white;
        }

    .btn-cancel {
        background: white;
        color: #64748b;
        border: 1px solid #e2e8f0;
    }

        .btn-cancel:hover {
            background: #f1f5f9;
            color: #334155;
        }

    /* BARRA MÓVIL */
    .mobile-topbar {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        height: 62px;
        background: rgba(240, 244, 248, 0.85);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid rgba(255,255,255,0.6);
        z-index: 250;
        align-items: center;
        padding: 0 16px;
    }

    .menu-toggle {
        width: 42px;
        height: 42px;
        border-radius: 12px;
        background: #0f172a;
        border: none;
        color: white;
        font-size: 1.1rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 15px rgba(0,0,0,0.2);
        flex-shrink: 0;
    }

    .sidebar-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.5);
        z-index: 150;
    }

    /* TABLET */
    @@media (max-width: 1024px) {
        .sidebar {
            width: 70px;
        }

        .sidebar-logo h2, .sidebar-logo p,
        .sidebar-section-title, .sidebar-item span,
        .user-details, .btn-logout-sidebar span {
            display: none;
        }

        .sidebar-item {
            justify-content: center;
            padding: 12px;
        }

        .user-info {
            justify-content: center;
        }

        .btn-logout-sidebar {
            justify-content: center;
        }

        .main-wrapper {
            margin-left: 70px;
            width: calc(100% - 70px);
        }

        .form-card {
            max-width: 100%;
        }
    }

    /* MÓVIL */
    @@media (max-width: 767px) {
        .mobile-topbar {
            display: flex;
        }

        .sidebar {
            width: 240px;
            transform: translateX(-100%);
        }

            .sidebar.open {
                transform: translateX(0);
            }

        .sidebar-logo h2, .sidebar-logo p,
        .sidebar-section-title, .sidebar-item span,
        .user-details, .btn-logout-sidebar span {
            display: block !important;
        }

        .sidebar-item {
            justify-content: flex-start !important;
            padding: 11px 12px !important;
        }

        .user-info {
            justify-content: flex-start !important;
        }

        .sidebar-overlay.open {
            display: block;
        }

        .main-wrapper {
            margin-left: 0 !important;
            width: 100% !important;
            padding: 16px;
            padding-top: 78px;
            align-items: stretch;
        }

        .topbar {
            max-width: 100%;
        }

        .topbar-title h1 {
            font-size: 1.3rem;
        }

        .form-card {
            max-width: 100%;
            border-radius: 16px;
        }

        .form-header {
            padding: 18px 16px;
        }

        .form-body {
            padding: 16px;
        }

        .form-grid {
            grid-template-columns: 1fr;
            gap: 14px;
        }

        .form-footer {
            padding: 16px;
            flex-direction: column-reverse;
            gap: 10px;
        }

            .form-footer .btn-action {
                width: 100%;
                justify-content: center;
            }
    }
</style>

<div class="mobile-topbar">
    <button class="menu-toggle" id="menuToggle">
        <i class="bi bi-list" id="menuIcon"></i>
    </button>
</div>
<div class="sidebar-overlay" id="sidebarOverlay"></div>

<div class="app-layout">
    <aside class="sidebar">
        <div class="sidebar-logo">
            <h2>Becarios<span>BD</span></h2>
            <p>Panel de Control</p>
        </div>
        <div class="sidebar-section">
            <p class="sidebar-section-title">Principal</p>
            <a class="sidebar-item" asp-page="/Productos/Inicio">
                <i class="bi bi-grid-1x2-fill"></i><span>Productos</span>
            </a>
            @if (User.IsInRole("Admin"))
            {
                <a class="sidebar-item" asp-page="/Usuarios/Index">
                    <i class="bi bi-people-fill"></i><span>Usuarios</span>
                </a>
                <a class="sidebar-item" asp-page="./Historial">
                    <i class="bi bi-clock-history"></i><span>Historial</span>
                </a>
            }
        </div>
        <div class="sidebar-section">
            <p class="sidebar-section-title">Herramientas</p>
            <a class="sidebar-item" asp-page="Importar">
                <i class="bi bi-file-earmark-arrow-up"></i><span>Importar CSV</span>
            </a>
            <a class="sidebar-item" asp-page="Crear">
                <i class="bi bi-plus-circle"></i><span>Nuevo Producto</span>
            </a>
        </div>
        <div class="sidebar-bottom">
            <div class="user-info">
                <div class="user-avatar">@User.Identity.Name?.Substring(0, 1).ToUpper()</div>
                <div class="user-details">
                    <div class="user-name">@User.Identity.Name</div>
                    <div class="user-role">@(User.IsInRole("Admin") ? "Administrador" : "Usuario")</div>
                </div>
            </div>
            <a asp-page="/Index" asp-page-handler="Logout" class="btn-logout-sidebar">
                <i class="bi bi-box-arrow-right"></i><span>Cerrar Sesion</span>
            </a>
        </div>
    </aside>

    <main class="main-wrapper">
        <div class="topbar">
            <div class="topbar-title">
                <h1>Editar Producto</h1>
                <p>Modifica los campos necesarios y guarda los cambios</p>
            </div>
        </div>

        <div class="form-card">
            <div class="form-header">
                <h2><i class="bi bi-pencil-square" style="color:#3b82f6;margin-right:8px;"></i>Editar Registro</h2>
                <p>Modifica los campos necesarios para actualizar el producto</p>
            </div>
            <form method="POST">
                <input type="hidden" asp-for="Producto.Id" />
                <div class="form-body">
                    <div class="form-grid">
                        <div class="form-group">
                            <label asp-for="Producto.CodigoProducto">Codigo</label>
                            <input asp-for="Producto.CodigoProducto" />
                            <span asp-validation-for="Producto.CodigoProducto" class="error-msg"></span>
                        </div>
                        <div class="form-group">
                            <label asp-for="Producto.Nombre">Nombre</label>
                            <input asp-for="Producto.Nombre" />
                            <span asp-validation-for="Producto.Nombre" class="error-msg"></span>
                        </div>
                        <div class="form-group">
                            <label asp-for="Producto.Precio">Precio</label>
                            <input asp-for="Producto.Precio" type="number" step="0.01" />
                            <span asp-validation-for="Producto.Precio" class="error-msg"></span>
                        </div>
                        <div class="form-group">
                            <label asp-for="Producto.Stock">Stock</label>
                            <input asp-for="Producto.Stock" type="number" />
                            <span asp-validation-for="Producto.Stock" class="error-msg"></span>
                        </div>
                    </div>
                </div>
                <div class="form-footer">
                    <a href="/Productos/Inicio" class="btn-action btn-cancel">
                        <i class="bi bi-x-lg"></i> Descartar
                    </a>
                    <button type="submit" class="btn-action btn-save">
                        <i class="bi bi-save"></i> Guardar Cambios
                    </button>
                </div>
            </form>
        </div>
    </main>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const menuToggle   = document.getElementById('menuToggle');
        const menuIcon     = document.getElementById('menuIcon');
        const sidebar      = document.querySelector('.sidebar');
        const overlay      = document.getElementById('sidebarOverlay');
        const mobileTopbar = document.querySelector('.mobile-topbar');

        function openSidebar() {
            sidebar.classList.add('open');
            overlay.classList.add('open');
            document.body.style.overflow = 'hidden';
            menuIcon.classList.replace('bi-list', 'bi-x-lg');
            mobileTopbar.style.display = 'none';
        }
        function closeSidebar() {
            sidebar.classList.remove('open');
            overlay.classList.remove('open');
            document.body.style.overflow = '';
            menuIcon.classList.replace('bi-x-lg', 'bi-list');
            mobileTopbar.style.display = 'flex';
        }

        menuToggle?.addEventListener('click', () => {
            sidebar.classList.contains('open') ? closeSidebar() : openSidebar();
        });
        overlay?.addEventListener('click', closeSidebar);
        sidebar?.querySelectorAll('.sidebar-item').forEach(item => {
            item.addEventListener('click', () => { if (window.innerWidth < 768) closeSidebar(); });
        });
        document.addEventListener('keydown', e => { if (e.key === 'Escape') closeSidebar(); });
    });
</script>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}