@page
@model Practica1.Pages.Productos.BorrarModel
@{
    ViewData["Title"] = "Borrar Producto - BecariosBD";
}

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

<style>
    /* 1. CONFIGURACIÓN DEL CUERPO (ESTILO LIGHT) */
    nav, .navbar, footer, header:not(.header-home) {
        display: none !important;
    }

    body {
        margin: 0;
        padding: 0;
        width: 100%;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        font-family: 'Inter', sans-serif;
        background-color: #ffffff;
        color: #333;
    }

    /* 2. CONTENEDOR PRINCIPAL (MISMA POSICIÓN) */
    .main-container {
        display: flex;
        justify-content: center;
        align-items: flex-start;
        width: 100%;
        padding: 60px 20px;
        box-sizing: border-box;
    }

    /* 3. TARJETA BLANCA (ANCHO 1100px) */
    .glass-card {
        background: #ffffff;
        padding: 50px;
        border-radius: 40px;
        width: 100%;
        max-width: 1100px;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.08);
        border: 1px solid #f0f0f0;
    }

    h1 {
        margin: 0 0 10px 0;
        text-align: center;
        font-weight: 800;
        letter-spacing: -1.5px;
        font-size: 2.8rem;
        text-transform: uppercase;
        color: #1a1a1a;
    }

    .warning-text {
        text-align: center;
        color: #d32f2f;
        font-weight: 600;
        margin-bottom: 40px;
        font-size: 1.1rem;
    }

    /* 4. ÁREA DE CONFIRMACIÓN */
    .info-content {
        max-width: 600px;
        margin: 0 auto;
        background-color: #fff5f5; /* Un tono rojizo muy suave para advertencia */
        padding: 40px;
        border-radius: 25px;
        border: 1px solid #ffcdd2;
    }

    .info-item {
        margin-bottom: 20px;
        border-bottom: 1px solid rgba(211, 47, 47, 0.1);
        padding-bottom: 15px;
    }

        .info-item:last-child {
            border-bottom: none;
            margin-bottom: 0;
        }

    .info-label {
        display: block;
        font-size: 0.8rem;
        color: darkred;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 2px;
        margin-bottom: 5px;
    }

    .info-value {
        font-size: 1.2rem;
        font-weight: 600;
        color: #1a1a1a;
    }

    /* 5. BOTONES */
    .btn-container {
        max-width: 600px;
        margin: 40px auto 0 auto;
        display: flex;
        gap: 20px;
    }

    .btn-cyber {
        flex: 2;
        padding: 18px;
        border-radius: 15px;
        border: none;
        background: #d32f2f; /* Rojo para borrar */
        color: white;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        cursor: pointer;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        text-decoration: none;
        box-shadow: 0 8px 20px rgba(211, 47, 47, 0.2);
    }

        .btn-cyber:hover {
            background: #b71c1c;
            transform: translateY(-3px);
            box-shadow: 0 12px 25px rgba(211, 47, 47, 0.3);
        }

    .btn-back {
        flex: 1;
        background: #ffffff;
        color: #666;
        border: 1px solid #ddd;
        box-shadow: none;
    }

        .btn-back:hover {
            background: #f5f5f5;
            color: #333;
            border-color: #ccc;
        }
</style>

<div class="main-container">
    <div class="glass-card">
        <h1>Eliminar Producto</h1>
        <p class="warning-text">¿Estás seguro de que deseas borrar permanentemente este producto?</p>

        <div class="info-content">
            <div class="info-item">
                <span class="info-label">Nombre del Producto</span>
                <span class="info-value">@Model.Producto.Nombre</span>
            </div>

            <div class="info-item">
                <span class="info-label">Precio</span>
                <span class="info-value">@Model.Producto.Precio.ToString("C")</span>
            </div>

            <div class="info-item">
                <span class="info-label">Stock que se perderá</span>
                <span class="info-value">@Model.Producto.Stock unidades</span>
            </div>
        </div>

        <form method="post">
            <div class="btn-container">
                <button type="submit" class="btn-cyber">
                    <i class="bi bi-trash3-fill"></i> Confirmar Eliminación
                </button>
                <a asp-page="./Inicio" class="btn-cyber btn-back">
                    <i class="bi bi-arrow-left"></i> Cancelar
                </a>
            </div>
        </form>
    </div>
</div>