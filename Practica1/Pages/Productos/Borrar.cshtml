@page
@model Practica1.Pages.Productos.BorrarModel
@{
    ViewData["Title"] = "Borrar Producto - BecariosBD";
}

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

<style>
    nav, .navbar, footer, header:not(.header-home) {
        display: none !important;
    }

    body {
        margin: 0;
        padding: 0;
        width: 100%;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        font-family: 'Inter', sans-serif;
        background-color: #ffffff;
        color: #333;
    }

    .main-container {
        display: flex;
        justify-content: center;
        align-items: flex-start;
        width: 100%;
        padding: 40px 15px;
        box-sizing: border-box;
    }

    .glass-card {
        background: #ffffff;
        padding: 40px 35px;
        border-radius: 30px;
        width: 100%;
        max-width: 1100px;
        box-shadow: 0 20px 60px rgba(0,0,0,0.08);
        border: 1px solid #f0f0f0;
        box-sizing: border-box;
    }

    h1 {
        margin: 0 0 10px 0;
        text-align: center;
        font-weight: 800;
        letter-spacing: -1px;
        font-size: clamp(1.6rem, 4vw, 2.8rem);
        text-transform: uppercase;
        color: #1a1a1a;
    }

    .warning-text {
        text-align: center;
        color: #d32f2f;
        font-weight: 600;
        margin-bottom: 35px;
        font-size: 1rem;
        padding: 0 10px;
    }

    .info-content {
        max-width: 600px;
        margin: 0 auto;
        background-color: #fff5f5;
        padding: 30px;
        border-radius: 20px;
        border: 1px solid #ffcdd2;
        box-sizing: border-box;
    }

    .info-item {
        margin-bottom: 18px;
        border-bottom: 1px solid rgba(211,47,47,0.1);
        padding-bottom: 14px;
    }

        .info-item:last-child {
            border-bottom: none;
            margin-bottom: 0;
        }

    .info-label {
        display: block;
        font-size: 0.78rem;
        color: darkred;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 2px;
        margin-bottom: 5px;
    }

    .info-value {
        font-size: 1.1rem;
        font-weight: 600;
        color: #1a1a1a;
    }

    .btn-container {
        max-width: 600px;
        margin: 30px auto 0 auto;
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
    }

    .btn-cyber {
        flex: 2;
        min-width: 140px;
        padding: 16px;
        border-radius: 13px;
        border: none;
        background: #d32f2f;
        color: white;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        cursor: pointer;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        text-decoration: none;
        box-shadow: 0 8px 20px rgba(211,47,47,0.2);
        font-family: 'Inter', sans-serif;
        font-size: 0.9rem;
    }

        .btn-cyber:hover {
            background: #b71c1c;
            transform: translateY(-3px);
            box-shadow: 0 12px 25px rgba(211,47,47,0.3);
        }

    .btn-back {
        flex: 1;
        min-width: 100px;
        background: #fff;
        color: #666;
        border: 1px solid #ddd;
        box-shadow: none;
    }

        .btn-back:hover {
            background: #f5f5f5;
            color: #333;
            border-color: #ccc;
        }

    @@media (max-width: 600px) {
        .glass-card

    {
        padding: 25px 15px;
        border-radius: 20px;
    }

    .main-container {
        padding: 20px 10px;
    }

    .btn-container {
        flex-direction: column;
    }

    .btn-cyber, .btn-back {
        flex: unset;
        width: 100%;
    }

    .info-content {
        padding: 20px 15px;
    }

    }
</style>

<div class="main-container">
    <div class="glass-card">
        <h1>Eliminar Producto</h1>
        <p class="warning-text">¿Estás seguro de que deseas borrar permanentemente este producto?</p>

        <div class="info-content">
            <div class="info-item">
                <span class="info-label">Nombre del Producto</span>
                <span class="info-value">@Model.Producto.Nombre</span>
            </div>
            <div class="info-item">
                <span class="info-label">Precio</span>
                <span class="info-value">@Model.Producto.Precio.ToString("C")</span>
            </div>
            <div class="info-item">
                <span class="info-label">Stock que se perderá</span>
                <span class="info-value">@Model.Producto.Stock unidades</span>
            </div>
        </div>

        <form method="post">
            <div class="btn-container">
                <button type="submit" class="btn-cyber">
                    <i class="bi bi-trash3-fill"></i> Confirmar Eliminación
                </button>
                <a asp-page="./Inicio" class="btn-cyber btn-back">
                    <i class="bi bi-arrow-left"></i> Cancelar
                </a>
            </div>
        </form>
    </div>
</div>