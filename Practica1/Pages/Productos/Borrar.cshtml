@page
@model Practica1.Pages.Productos.BorrarModel
@{
    ViewData["Title"] = "Borrar Producto - BecariosBD";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

<style>
    /* SIDEBAR EXACTO */
    nav, .navbar, footer, header:not(.header-home) {
        display: none !important;
    }

    body {
        margin: 0;
        padding: 0;
        width: 100%;
        min-height: 100vh;
        font-family: 'Inter', sans-serif;
        background-color: #f8fafc;
        color: #1e293b;
    }

    .app-container {
        display: flex;
        min-height: 100vh;
    }

    /* SIDEBAR */
    .sidebar {
        width: 240px;
        min-height: 100vh;
        background: #0f172a;
        display: flex;
        flex-direction: column;
        padding: 30px 0;
        position: fixed;
        top: 0;
        left: 0;
        z-index: 100;
        transition: width 0.3s ease;
    }

    .sidebar-logo {
        padding: 0 25px 30px 25px;
        border-bottom: 1px solid rgba(255,255,255,0.06);
        margin-bottom: 20px;
    }

        .sidebar-logo h2 {
            color: #fff;
            font-size: 1.1rem;
            font-weight: 800;
            margin: 0;
            letter-spacing: -0.5px;
            text-transform: uppercase;
        }

        .sidebar-logo span {
            color: #3b82f6;
        }

        .sidebar-logo p {
            color: #64748b;
            font-size: 0.72rem;
            margin: 4px 0 0 0;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

    .sidebar-section {
        padding: 0 15px;
        margin-bottom: 25px;
    }

    .sidebar-section-title {
        color: #475569;
        font-size: 0.65rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        padding: 0 10px;
        margin-bottom: 8px;
    }

    .sidebar-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 11px 12px;
        border-radius: 10px;
        color: #94a3b8;
        text-decoration: none;
        font-size: 0.88rem;
        font-weight: 500;
        transition: all 0.2s ease;
        margin-bottom: 3px;
        cursor: pointer;
        border: none;
        background: transparent;
        width: 100%;
    }

        .sidebar-item:hover {
            background: rgba(255,255,255,0.07);
            color: #fff;
        }

        .sidebar-item.active {
            background: linear-gradient(135deg, #1d4ed8, #3b82f6);
            color: #fff;
            box-shadow: 0 4px 15px rgba(59,130,246,0.3);
        }

        .sidebar-item i {
            font-size: 1rem;
            width: 20px;
            text-align: center;
        }

    .sidebar-bottom {
        margin-top: auto;
        padding: 20px 15px;
        border-top: 1px solid rgba(255,255,255,0.06);
    }

    .user-info {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px;
        border-radius: 10px;
        background: rgba(255,255,255,0.05);
        margin-bottom: 10px;
    }

    .user-avatar {
        width: 36px;
        height: 36px;
        border-radius: 10px;
        background: linear-gradient(135deg, #1d4ed8, #3b82f6);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: 700;
        font-size: 0.9rem;
        flex-shrink: 0;
    }

    .user-details {
        overflow: hidden;
    }

    .user-name {
        color: #e2e8f0;
        font-size: 0.82rem;
        font-weight: 600;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .user-role {
        color: #64748b;
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .btn-logout-sidebar {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 10px 12px;
        border-radius: 10px;
        color: #ef4444;
        background: rgba(239,68,68,0.08);
        border: 1px solid rgba(239,68,68,0.15);
        text-decoration: none;
        font-size: 0.82rem;
        font-weight: 600;
        transition: all 0.2s ease;
        width: 100%;
        justify-content: center;
    }

        .btn-logout-sidebar:hover {
            background: #ef4444;
            color: white;
        }

    /* CONTENIDO ESPECIFICO BORRAR */
    .main-wrapper {
        margin-left: 280px;
        flex: 1;
        padding: 40px;
    }

    .delete-card {
        background: #fff;
        border-radius: 24px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.02);
        border: 1px solid #fee2e2;
        max-width: 600px;
        margin: 0 auto;
        overflow: hidden;
    }

    .warning-header {
        background: #fef2f2;
        padding: 30px;
        border-bottom: 1px solid #fee2e2;
        display: flex;
        align-items: center;
        gap: 20px;
        color: #991b1b;
    }

        .warning-header i {
            font-size: 2.5rem;
        }

        .warning-header h1 {
            margin: 0;
            font-size: 1.4rem;
            font-weight: 800;
        }

    .info-body {
        padding: 30px;
    }

    .info-group {
        margin-bottom: 18px;
        padding-bottom: 14px;
        border-bottom: 1px solid #f1f5f9;
    }

    .info-label {
        display: block;
        font-size: 0.7rem;
        font-weight: 700;
        color: #64748b;
        text-transform: uppercase;
        margin-bottom: 4px;
    }

    .info-value {
        font-size: 1.1rem;
        font-weight: 600;
        color: #0f172a;
    }

    /* BOTONES ESTILO CREAR */
    .form-footer {
        padding: 24px 30px;
        background: #f8fafc;
        border-top: 1px solid #f1f5f9;
        display: flex;
        justify-content: flex-end;
        gap: 12px;
    }

    .btn-action {
        padding: 12px 24px;
        border-radius: 12px;
        font-weight: 700;
        font-size: 0.9rem;
        border: none;
        cursor: pointer;
        transition: all 0.2s;
        display: flex;
        align-items: center;
        gap: 8px;
        text-decoration: none;
    }

    .btn-delete {
        background: #ef4444;
        color: white;
    }

        .btn-delete:hover {
            background: #dc2626;
            transform: translateY(-2px);
        }

    .btn-cancel {
        background: white;
        color: #64748b;
        border: 1px solid #e2e8f0;
    }

        .btn-cancel:hover {
            background: #f1f5f9;
        }
</style>

<div class="app-container">
    <!-- SIDEBAR -->
    <aside class="sidebar">
        <div class="sidebar-logo">
            <h2>Becarios<span>BD</span></h2>
            <p>Panel de Control</p>
        </div>

        <div class="sidebar-section">
            <p class="sidebar-section-title">Principal</p>
            <a class="sidebar-item" href="/Productos/Inicio">
                <i class="bi bi-grid-1x2-fill"></i>
                <span>Productos</span>
            </a>
            @if (User.IsInRole("Admin"))
            {
                <a class="sidebar-item" asp-page="/Usuarios/Index">
                    <i class="bi bi-people-fill"></i>
                    <span>Usuarios</span>
                </a>
                <a class="sidebar-item" asp-page="./Historial">
                    <i class="bi bi-clock-history"></i>
                    <span>Historial</span>
                </a>
            }
        </div>

        <div class="sidebar-section">
            <p class="sidebar-section-title">Herramientas</p>
            <a class="sidebar-item" asp-page="Importar">
                <i class="bi bi-file-earmark-arrow-up"></i>
                <span>Importar CSV</span>
            </a>
            <a class="sidebar-item" asp-page="Crear">
                <a class="sidebar-item" href="#">
                    <i class="bi bi-plus-circle"></i>
                    <span>Nuevo Producto</span>
                </a>
            </a>
        </div>

        <div class="sidebar-bottom">
            <div class="user-info">
                <div class="user-avatar">
                    @User.Identity.Name?.Substring(0, 1).ToUpper()
                </div>
                <div class="user-details">
                    <div class="user-name">@User.Identity.Name</div>
                    <div class="user-role">@(User.IsInRole("Admin") ? "Administrador" : "Usuario")</div>
                </div>
            </div>
            <a asp-page="/Index" asp-page-handler="Logout" class="btn-logout-sidebar">
                <i class="bi bi-box-arrow-right"></i>
                <span>Cerrar Sesion</span>
            </a>
        </div>
    </aside>

    <main class="main-wrapper">
        <div class="delete-card">
            <div class="warning-header">
                <i class="bi bi-exclamation-triangle-fill"></i>
                <div>
                    <h1>Eliminar Producto</h1>
                    <p style="margin:0; font-size:0.85rem">¿Estás seguro? Esta acción es irreversible.</p>
                </div>
            </div>
            <div class="info-body">
                <div class="info-group"><span class="info-label">Nombre</span><span class="info-value">@Model.Producto.Nombre</span></div>
                <div class="info-group"><span class="info-label">Código</span><span class="info-value">@Model.Producto.CodigoProducto</span></div>
                <div class="info-group"><span class="info-label">Stock a eliminar</span><span class="info-value">@Model.Producto.Stock unidades</span></div>
            </div>
            <form method="post">
                <div class="form-footer">
                    <a href="/Productos/Inicio" class="btn-action btn-cancel">Cancelar</a>
                    <button type="submit" class="btn-action btn-delete"><i class="bi bi-trash3-fill"></i> Confirmar</button>
                </div>
            </form>
        </div>
    </main>
</div>