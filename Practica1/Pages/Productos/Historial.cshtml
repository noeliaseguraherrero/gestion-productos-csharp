@page
@model Practica1.Pages.Productos.HistorialModel
@{
    ViewData["Title"] = "Historial - BecariosBD";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

<style>
    nav, .navbar, footer, header:not(.header-home) {
        display: none !important;
    }

    *, *::before, *::after {
        box-sizing: border-box;
    }

    body {
        margin: 0;
        padding: 0;
        width: 100%;
        min-height: 100vh;
        font-family: 'Inter', sans-serif;
        background: linear-gradient(135deg, #f0f4f8 0%, #e8edf2 100%);
        color: #1a1a2e;
    }

    .app-layout {
        display: flex;
        min-height: 100vh;
    }

    .sidebar {
        width: 240px;
        min-height: 100vh;
        background: #0f172a;
        display: flex;
        flex-direction: column;
        padding: 30px 0;
        position: fixed;
        top: 0;
        left: 0;
        z-index: 200; /* ← cambia de 100 a 200 */
        transition: transform 0.3s ease, width 0.3s ease; /* ← añade transform */
    }

    .sidebar-logo {
        padding: 0 25px 30px 25px;
        border-bottom: 1px solid rgba(255,255,255,0.06);
        margin-bottom: 20px;
    }

        .sidebar-logo h2 {
            color: #fff;
            font-size: 1.1rem;
            font-weight: 800;
            margin: 0;
            letter-spacing: -0.5px;
            text-transform: uppercase;
        }

        .sidebar-logo span {
            color: #3b82f6;
        }

        .sidebar-logo p {
            color: #64748b;
            font-size: 0.72rem;
            margin: 4px 0 0 0;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

    .sidebar-section {
        padding: 0 15px;
        margin-bottom: 25px;
    }

    .sidebar-section-title {
        color: #475569;
        font-size: 0.65rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        padding: 0 10px;
        margin-bottom: 8px;
    }

    .sidebar-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 11px 12px;
        border-radius: 10px;
        color: #94a3b8;
        text-decoration: none;
        font-size: 0.88rem;
        font-weight: 500;
        transition: all 0.2s ease;
        margin-bottom: 3px;
        cursor: pointer;
        border: none;
        background: transparent;
        width: 100%;
    }

        .sidebar-item:hover {
            background: rgba(255,255,255,0.07);
            color: #fff;
        }

        .sidebar-item.active {
            background: linear-gradient(135deg, #1d4ed8, #3b82f6);
            color: #fff;
            box-shadow: 0 4px 15px rgba(59,130,246,0.3);
        }

        .sidebar-item i {
            font-size: 1rem;
            width: 20px;
            text-align: center;
        }

    .sidebar-bottom {
        margin-top: auto;
        padding: 20px 15px;
        border-top: 1px solid rgba(255,255,255,0.06);
    }

    .user-info {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px;
        border-radius: 10px;
        background: rgba(255,255,255,0.05);
        margin-bottom: 10px;
    }

    .user-avatar {
        width: 36px;
        height: 36px;
        border-radius: 10px;
        background: linear-gradient(135deg, #1d4ed8, #3b82f6);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: 700;
        font-size: 0.9rem;
        flex-shrink: 0;
    }

    .user-details {
        overflow: hidden;
    }

    .user-name {
        color: #e2e8f0;
        font-size: 0.82rem;
        font-weight: 600;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .user-role {
        color: #64748b;
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .btn-logout-sidebar {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 10px 12px;
        border-radius: 10px;
        color: #ef4444;
        background: rgba(239,68,68,0.08);
        border: 1px solid rgba(239,68,68,0.15);
        text-decoration: none;
        font-size: 0.82rem;
        font-weight: 600;
        transition: all 0.2s ease;
        width: 100%;
        justify-content: center;
    }

        .btn-logout-sidebar:hover {
            background: #ef4444;
            color: white;
        }

    .main-content {
        margin-left: 240px;
        flex: 1;
        padding: 30px;
        min-height: 100vh;
    }

    .topbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
    }

    .topbar-title h1 {
        font-size: 1.6rem;
        font-weight: 800;
        color: #0f172a;
        margin: 0;
        letter-spacing: -0.5px;
    }

    .topbar-title p {
        color: #64748b;
        font-size: 0.85rem;
        margin: 4px 0 0 0;
    }

    /* STATS */
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
        margin-bottom: 30px;
    }

    .stat-card {
        background: #fff;
        border-radius: 20px;
        padding: 22px;
        border: 1px solid #f1f5f9;
        box-shadow: 0 2px 15px rgba(0,0,0,0.04);
        display: flex;
        align-items: center;
        gap: 16px;
        position: relative;
        overflow: hidden;
        transition: all 0.3s ease;
    }

        .stat-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
        }

        .stat-card.green::before {
            background: linear-gradient(90deg, #15803d, #22c55e);
        }

        .stat-card.blue::before {
            background: linear-gradient(90deg, #1d4ed8, #3b82f6);
        }

        .stat-card.red::before {
            background: linear-gradient(90deg, #be123c, #ef4444);
        }

        .stat-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 15px 35px rgba(0,0,0,0.08);
        }

    .stat-icon {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.3rem;
        flex-shrink: 0;
    }

        .stat-icon.green {
            background: #f0fdf4;
            color: #15803d;
        }

        .stat-icon.blue {
            background: #eff6ff;
            color: #1d4ed8;
        }

        .stat-icon.red {
            background: #fff1f2;
            color: #be123c;
        }

    .stat-info h4 {
        margin: 0 0 3px 0;
        font-size: 0.7rem;
        color: #94a3b8;
        text-transform: uppercase;
        letter-spacing: 1px;
        font-weight: 700;
    }

    .stat-info p {
        margin: 0;
        font-size: 1.5rem;
        font-weight: 800;
        color: #0f172a;
        letter-spacing: -1px;
    }

    /* TABLA CARD */
    .table-card {
        background: #fff;
        border-radius: 20px;
        border: 1px solid #f1f5f9;
        box-shadow: 0 2px 15px rgba(0,0,0,0.04);
        overflow: hidden;
    }

    .table-card-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        padding: 22px 25px;
        border-bottom: 1px solid #f1f5f9;
        flex-wrap: wrap;
        gap: 15px;
    }

    .table-card-title {
        font-size: 1rem;
        font-weight: 700;
        color: #0f172a;
        margin: 0;
    }

        .table-card-title p {
            color: #64748b;
            font-size: 0.82rem;
            margin: 4px 0 0 0;
            font-weight: 400;
        }

    /* FILTROS */
    .filters-bar {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        align-items: center;
    }

    .filter-select, .filter-input {
        padding: 9px 13px;
        border-radius: 10px;
        border: 1px solid #e2e8f0;
        background: #f8fafc;
        font-family: 'Inter', sans-serif;
        font-size: 0.85rem;
        outline: none;
        color: #0f172a;
        transition: all 0.2s;
    }

        .filter-select:focus, .filter-input:focus {
            border-color: #3b82f6;
            background: #fff;
            box-shadow: 0 0 0 3px rgba(59,130,246,0.1);
        }

    .btn-filter {
        padding: 9px 18px;
        border-radius: 10px;
        background: linear-gradient(135deg, #1d4ed8, #3b82f6);
        color: white;
        border: none;
        font-family: 'Inter', sans-serif;
        font-size: 0.85rem;
        font-weight: 700;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        transition: all 0.2s;
    }

        .btn-filter:hover {
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(59,130,246,0.3);
        }

    .btn-clear {
        padding: 9px 16px;
        border-radius: 10px;
        background: white;
        color: #64748b;
        border: 1px solid #e2e8f0;
        font-size: 0.85rem;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        transition: all 0.2s;
    }

        .btn-clear:hover {
            background: #f1f5f9;
            color: #334155;
        }

    /* TABLA */
    .table-wrapper {
        overflow-x: auto;
    }

    .custom-table {
        width: 100%;
        border-collapse: collapse;
        min-width: 700px;
    }

        .custom-table th {
            padding: 13px 20px;
            text-align: left;
            font-size: 0.72rem;
            font-weight: 700;
            color: #94a3b8;
            text-transform: uppercase;
            letter-spacing: 0.8px;
            background: #f8fafc;
            border-bottom: 1px solid #f1f5f9;
            white-space: nowrap;
        }

        .custom-table td {
            padding: 16px 20px;
            border-bottom: 1px solid #f8fafc;
            font-size: 0.88rem;
            vertical-align: middle;
        }

        .custom-table tbody tr {
            transition: background 0.15s ease;
        }

            .custom-table tbody tr:hover {
                background: #f8fafc;
            }

            .custom-table tbody tr:last-child td {
                border-bottom: none;
            }

    /* BADGES */
    .badge-accion {
        padding: 4px 12px;
        border-radius: 20px;
        font-weight: 700;
        font-size: 0.72rem;
        text-transform: uppercase;
        display: inline-flex;
        align-items: center;
        gap: 5px;
    }

    .badge-crear {
        background: #f0fdf4;
        color: #15803d;
        border: 1px solid #bbf7d0;
    }

    .badge-editar {
        background: #eff6ff;
        color: #1d4ed8;
        border: 1px solid #bfdbfe;
    }

    .badge-eliminar {
        background: #fff1f2;
        color: #be123c;
        border: 1px solid #fecdd3;
    }

    /* PAGINACION */
    .pagination-container {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 18px 25px;
        border-top: 1px solid #f1f5f9;
        flex-wrap: wrap;
        gap: 10px;
    }

    .pagination-info {
        font-size: 0.82rem;
        color: #94a3b8;
    }

    .pagination-btns {
        display: flex;
        gap: 6px;
    }

    .btn-page {
        width: 36px;
        height: 36px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 9px;
        background: white;
        border: 1px solid #e2e8f0;
        color: #475569;
        text-decoration: none;
        font-weight: 600;
        font-size: 0.85rem;
        transition: all 0.2s ease;
    }

        .btn-page:hover:not(.disabled) {
            background: #3b82f6;
            color: white;
            border-color: #3b82f6;
        }

        .btn-page.disabled {
            opacity: 0.35;
            cursor: not-allowed;
        }

    /* EMPTY */
    .empty-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 60px 20px;
        gap: 12px;
        text-align: center;
    }

    .empty-icon {
        width: 70px;
        height: 70px;
        border-radius: 20px;
        background: #f1f5f9;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #cbd5e1;
        font-size: 1.8rem;
    }

    .empty-state h3 {
        margin: 0;
        font-size: 1rem;
        font-weight: 700;
        color: #334155;
    }

    .empty-state p {
        margin: 4px 0 0 0;
        color: #94a3b8;
        font-size: 0.88rem;
    }
    /* BARRA MÓVIL */
    .mobile-topbar {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        height: 62px;
        background: rgba(240, 244, 248, 0.85);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid rgba(255,255,255,0.6);
        z-index: 250;
        align-items: center;
        padding: 0 16px;
    }

    .menu-toggle {
        width: 42px;
        height: 42px;
        border-radius: 12px;
        background: #0f172a;
        border: none;
        color: white;
        font-size: 1.1rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 15px rgba(0,0,0,0.2);
        transition: opacity 0.2s ease;
        flex-shrink: 0;
    }

    .sidebar-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.5);
        z-index: 150;
    }

    /* TABLET */
    @@media (max-width: 1024px) {
        .sidebar {
            width: 70px;
        }

        .sidebar-logo h2, .sidebar-logo p,
        .sidebar-section-title, .sidebar-item span,
        .user-details, .btn-logout-sidebar span {
            display: none;
        }

        .sidebar-item {
            justify-content: center;
            padding: 12px;
        }

        .user-info {
            justify-content: center;
        }

        .btn-logout-sidebar {
            justify-content: center;
        }

        .main-content {
            margin-left: 70px;
        }

        .stats-grid {
            grid-template-columns: 1fr 1fr;
        }

        .table-card-header {
            flex-direction: column;
            align-items: stretch;
        }

        .filters-bar {
            flex-direction: column;
            align-items: stretch;
        }

        .filter-select, .filter-input, .btn-filter, .btn-clear {
            width: 100%;
            justify-content: center;
        }
    }

    /* MÓVIL */
    @@media (max-width: 767px) {
        .mobile-topbar {
            display: flex;
        }

        .sidebar {
            width: 240px;
            transform: translateX(-100%);
        }

            .sidebar.open {
                transform: translateX(0);
            }

        .sidebar-logo h2, .sidebar-logo p,
        .sidebar-section-title, .sidebar-item span,
        .user-details, .btn-logout-sidebar span {
            display: block !important;
        }

        .sidebar-item {
            justify-content: flex-start !important;
            padding: 11px 12px !important;
        }

        .user-info {
            justify-content: flex-start !important;
        }

        .sidebar-overlay.open {
            display: block;
        }

        .main-content {
            margin-left: 0 !important;
            width: 100% !important;
            padding: 16px;
            padding-top: 78px;
            min-width: 0;
        }

        .topbar {
            flex-direction: column;
            align-items: flex-start;
            gap: 12px;
        }

        .topbar-title h1 {
            font-size: 1.3rem;
        }

        .stats-grid {
            grid-template-columns: 1fr;
            gap: 12px;
        }

        .stat-card {
            padding: 18px;
        }

        .stat-info p {
            font-size: 1.3rem;
        }

        .table-card-header {
            flex-direction: column;
            align-items: stretch;
            gap: 14px;
            padding: 16px;
        }

        .filters-bar {
            flex-direction: column;
            align-items: stretch;
            gap: 8px;
        }

        .filter-select, .filter-input {
            width: 100%;
        }

        .btn-filter, .btn-clear {
            width: 100%;
            justify-content: center;
        }
        /* Ocultar tabla, mostrar tarjetas */
        .table-wrapper {
            display: none;
        }

        .history-cards {
            display: flex;
            flex-direction: column;
            gap: 10px;
            padding: 15px;
        }

        .history-card {
            background: #fff;
            border: 1px solid #f1f5f9;
            border-radius: 14px;
            padding: 14px 16px;
        }

        .history-card-top {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 10px;
            flex-wrap: wrap;
            gap: 8px;
        }

        .history-card-row {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            padding: 7px 0;
            border-bottom: 1px solid #f8fafc;
            font-size: 0.85rem;
            gap: 10px;
        }

            .history-card-row:last-child {
                border-bottom: none;
            }

        .history-card-label {
            font-size: 0.68rem;
            color: #94a3b8;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.8px;
            flex-shrink: 0;
            min-width: 70px;
        }

        .history-card-value {
            font-weight: 500;
            color: #334155;
            text-align: right;
            font-size: 0.85rem;
        }

        .pagination-container {
            flex-direction: column;
            align-items: center;
            gap: 12px;
        }
    }

    @@media (min-width: 768px) {
        .history-cards {
            display: none;
        }
    }
</style>

<div class="mobile-topbar">
    <button class="menu-toggle" id="menuToggle">
        <i class="bi bi-list" id="menuIcon"></i>
    </button>
</div>
<div class="sidebar-overlay" id="sidebarOverlay"></div>

<div class="app-layout">
    <aside class="sidebar">
        <div class="sidebar-logo">
            <h2>Becarios<span>BD</span></h2>
            <p>Panel de Control</p>
        </div>
        <div class="sidebar-section">
            <p class="sidebar-section-title">Principal</p>
            <a class="sidebar-item" asp-page="/Productos/Inicio">
                <i class="bi bi-grid-1x2-fill"></i><span>Productos</span>
            </a>
            @if (User.IsInRole("Admin"))
            {
                <a class="sidebar-item" asp-page="/Usuarios/Index">
                    <i class="bi bi-people-fill"></i><span>Usuarios</span>
                </a>
                <a class="sidebar-item active" asp-page="./Historial">
                    <i class="bi bi-clock-history"></i><span>Historial</span>
                </a>
            }
        </div>
        <div class="sidebar-section">
            <p class="sidebar-section-title">Herramientas</p>
            <a class="sidebar-item" asp-page="Importar">
                <i class="bi bi-file-earmark-arrow-up"></i><span>Importar CSV</span>
            </a>
            <a class="sidebar-item" asp-page="Crear">
                <i class="bi bi-plus-circle"></i><span>Nuevo Producto</span>
            </a>
        </div>
        <div class="sidebar-bottom">
            <div class="user-info">
                <div class="user-avatar">@User.Identity.Name?.Substring(0, 1).ToUpper()</div>
                <div class="user-details">
                    <div class="user-name">@User.Identity.Name</div>
                    <div class="user-role">@(User.IsInRole("Admin") ? "Administrador" : "Usuario")</div>
                </div>
            </div>
            <a asp-page="/Index" asp-page-handler="Logout" class="btn-logout-sidebar">
                <i class="bi bi-box-arrow-right"></i><span>Cerrar Sesion</span>
            </a>
        </div>
    </aside>

    <main class="main-content">
        <div class="topbar">
            <div class="topbar-title">
                <h1>Historial de Auditoria</h1>
                <p>Seguimiento completo de cambios en el inventario</p>
            </div>
        </div>

        <!-- STATS -->
        <div class="stats-grid">
            <div class="stat-card green">
                <div class="stat-icon green"><i class="bi bi-plus-circle"></i></div>
                <div class="stat-info">
                    <h4>Creaciones</h4>
                    <p>@Model.Historial.Count(h => h.Accion == "Crear")</p>
                </div>
            </div>
            <div class="stat-card blue">
                <div class="stat-icon blue"><i class="bi bi-pencil-square"></i></div>
                <div class="stat-info">
                    <h4>Ediciones</h4>
                    <p>@Model.Historial.Count(h => h.Accion == "Editar")</p>
                </div>
            </div>
            <div class="stat-card red">
                <div class="stat-icon red"><i class="bi bi-trash3"></i></div>
                <div class="stat-info">
                    <h4>Eliminaciones</h4>
                    <p>@Model.Historial.Count(h => h.Accion == "Eliminar")</p>
                </div>
            </div>
        </div>

        <!-- TABLA -->
        <div class="table-card">
            <div class="table-card-header">
                <div>
                    <h3 class="table-card-title">
                        <i class="bi bi-clock-history" style="color:#3b82f6;margin-right:8px;"></i>Registro de Acciones
                    </h3>
                    <p>Filtra por accion, usuario o fecha</p>
                </div>
                <form method="get" class="filters-bar">
                    <select name="accion" class="filter-select">
                        <option value="">Accion: Todas</option>
                        <option value="Crear" selected="@(Model.FiltroAccion == "Crear")">Crear</option>
                        <option value="Editar" selected="@(Model.FiltroAccion == "Editar")">Editar</option>
                        <option value="Eliminar" selected="@(Model.FiltroAccion == "Eliminar")">Eliminar</option>
                    </select>
                    <select name="usuarioId" class="filter-select">
                        <option value="">Usuario: Todos</option>
                        @foreach (var usuario in Model.Usuarios)
                        {
                            <option value="@usuario.Id" selected="@(Model.FiltroUsuarioId == usuario.Id)">@usuario.Nombre</option>
                        }
                    </select>
                    <input type="date" name="fecha" class="filter-input" value="@Model.FiltroFecha" />
                    <button type="submit" class="btn-filter"><i class="bi bi-funnel"></i> Filtrar</button>
                    <a asp-page="./Historial" class="btn-clear"><i class="bi bi-x-lg"></i> Limpiar</a>
                </form>
            </div>

            <div class="table-wrapper">
                <table class="custom-table">
                    <thead>
                        <tr>
                            <th>Accion</th>
                            <th>Producto / Codigo</th>
                            <th>Usuario</th>
                            <th>Fecha y Hora</th>
                            <th>Cambios</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Historial.Any())
                        {
                            @foreach (var item in Model.Historial)
                            {
                                <tr>
                                    <td>
                                        <span class="badge-accion @(item.Accion == "Crear" ? "badge-crear" : item.Accion == "Editar" ? "badge-editar" : "badge-eliminar")">
                                            <i class="bi @(item.Accion == "Crear" ? "bi-plus-circle" : item.Accion == "Editar" ? "bi-pencil-square" : "bi-trash3")"></i>
                                            @item.Accion
                                        </span>
                                    </td>
                                    <td>
                                        <div style="font-weight:600;color:#0f172a;">@item.NombreProducto</div>
                                        <div style="color:#94a3b8;font-size:0.78rem;">@item.CodigoProducto</div>
                                    </td>
                                    <td>
                                        <div style="display:flex;align-items:center;gap:8px;">
                                            <div style="width:28px;height:28px;border-radius:8px;background:linear-gradient(135deg,#1d4ed8,#3b82f6);display:flex;align-items:center;justify-content:center;color:white;font-size:0.72rem;font-weight:700;flex-shrink:0;">
                                                @(item.Usuario?.Nombre?.Substring(0, 1).ToUpper() ?? "?")
                                            </div>
                                            <span style="font-weight:500;color:#334155;">@item.Usuario?.Nombre</span>
                                        </div>
                                    </td>
                                    <td>
                                        <div style="font-weight:600;color:#0f172a;font-size:0.85rem;">@item.Fecha.ToString("dd/MM/yyyy")</div>
                                        <div style="color:#94a3b8;font-size:0.78rem;">@item.Fecha.ToString("HH:mm")</div>
                                    </td>
                                    <td style="color:#64748b;font-size:0.82rem;max-width:280px;">
                                        @item.Detalles.Replace("?", "→")
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5">
                                    <div class="empty-state">
                                        <div class="empty-icon"><i class="bi bi-search"></i></div>
                                        <h3>Sin resultados</h3>
                                        <p>No hay registros que coincidan con los filtros aplicados.</p>
                                        <a asp-page="./Historial" style="color:#3b82f6;font-weight:600;font-size:0.88rem;text-decoration:none;">Limpiar filtros</a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- TARJETAS HISTORIAL MÓVIL -->
            <div class="history-cards">
                @if (Model.Historial.Any())
                {
                    @foreach (var item in Model.Historial)
                    {
                        <div class="history-card">
                            <div class="history-card-top">
                                <span class="badge-accion @(item.Accion == "Crear" ? "badge-crear" : item.Accion == "Editar" ? "badge-editar" : "badge-eliminar")">
                                    <i class="bi @(item.Accion == "Crear" ? "bi-plus-circle" : item.Accion == "Editar" ? "bi-pencil-square" : "bi-trash3")"></i>
                                    @item.Accion
                                </span>
                                <span style="color:#94a3b8;font-size:0.78rem;">@item.Fecha.ToString("dd/MM/yyyy HH:mm")</span>
                            </div>
                            <div class="history-card-row">
                                <span class="history-card-label">Producto</span>
                                <span class="history-card-value">@item.NombreProducto</span>
                            </div>
                            <div class="history-card-row">
                                <span class="history-card-label">Codigo</span>
                                <span class="history-card-value">@item.CodigoProducto</span>
                            </div>
                            <div class="history-card-row">
                                <span class="history-card-label">Usuario</span>
                                <span class="history-card-value">@item.Usuario?.Nombre</span>
                            </div>
                            <div class="history-card-row">
                                <span class="history-card-label">Cambios</span>
                                <span class="history-card-value" style="color:#64748b;font-size:0.8rem;">
                                    @item.Detalles.Replace("?", "→")
                                </span>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="empty-state">
                        <div class="empty-icon"><i class="bi bi-search"></i></div>
                        <h3>Sin resultados</h3>
                        <p>No hay registros que coincidan.</p>
                    </div>
                }
            </div>

            @if (Model.TotalPaginas > 1)
            {
                <div class="pagination-container">
                    <span class="pagination-info">
                        Pagina <strong>@Model.PaginaActual</strong> de <strong>@Model.TotalPaginas</strong>
                    </span>
                    <div class="pagination-btns">
                        @if (Model.PaginaActual > 1)
                        {
                            <a asp-page="./Historial" asp-route-pagina="@(Model.PaginaActual - 1)" class="btn-page"><i class="bi bi-chevron-left"></i></a>
                        }
                        else
                        {
                            <span class="btn-page disabled"><i class="bi bi-chevron-left"></i></span>
                        }
                        @if (Model.PaginaActual < Model.TotalPaginas)
                        {
                            <a asp-page="./Historial" asp-route-pagina="@(Model.PaginaActual + 1)" class="btn-page"><i class="bi bi-chevron-right"></i></a>
                        }
                        else
                        {
                            <span class="btn-page disabled"><i class="bi bi-chevron-right"></i></span>
                        }
                    </div>
                </div>
            }
        </div>
    </main>
</div>
<script>
    document.addEventListener('DOMContentLoaded', function () {
        const menuToggle   = document.getElementById('menuToggle');
        const menuIcon     = document.getElementById('menuIcon');
        const sidebar      = document.querySelector('.sidebar');
        const overlay      = document.getElementById('sidebarOverlay');
        const mobileTopbar = document.querySelector('.mobile-topbar');

        function openSidebar() {
            sidebar.classList.add('open');
            overlay.classList.add('open');
            document.body.style.overflow = 'hidden';
            menuIcon.classList.replace('bi-list', 'bi-x-lg');
            mobileTopbar.style.display = 'none';
        }
        function closeSidebar() {
            sidebar.classList.remove('open');
            overlay.classList.remove('open');
            document.body.style.overflow = '';
            menuIcon.classList.replace('bi-x-lg', 'bi-list');
            mobileTopbar.style.display = 'flex';
        }

        menuToggle?.addEventListener('click', () => {
            sidebar.classList.contains('open') ? closeSidebar() : openSidebar();
        });
        overlay?.addEventListener('click', closeSidebar);
        sidebar?.querySelectorAll('.sidebar-item').forEach(item => {
            item.addEventListener('click', () => { if (window.innerWidth < 768) closeSidebar(); });
        });
        document.addEventListener('keydown', e => { if (e.key === 'Escape') closeSidebar(); });
    });
</script>