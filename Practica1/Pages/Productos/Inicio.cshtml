@page
@model Practica1.Pages.Productos.InicioModel
@using System.Security.Claims
@{
    ViewData["Title"] = "Panel de Control - BecariosBD";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<style>
    nav, .navbar, footer, header:not(.header-home) {
        display: none !important;
    }

    *, *::before, *::after {
        box-sizing: border-box;
    }

    body {
        margin: 0;
        padding: 0;
        width: 100%;
        min-height: 100vh;
        font-family: 'Inter', sans-serif;
        background: linear-gradient(135deg, #f0f4f8 0%, #e8edf2 100%);
        color: #1a1a2e;
    }

    /* LAYOUT */
    .app-layout {
        display: flex;
        min-height: 100vh;
    }

    /* SIDEBAR */
    .sidebar {
        width: 240px;
        min-height: 100vh;
        background: #0f172a;
        display: flex;
        flex-direction: column;
        padding: 30px 0;
        position: fixed;
        top: 0;
        left: 0;
        z-index: 100;
        transition: width 0.3s ease;
        z-index: 200; /* ← cambia de 100 a 200 */
        transition: transform 0.3s ease, width 0.3s ease; /* ← añade transform */
    }

    .sidebar-logo {
        padding: 0 25px 30px 25px;
        border-bottom: 1px solid rgba(255,255,255,0.06);
        margin-bottom: 20px;
    }

        .sidebar-logo h2 {
            color: #fff;
            font-size: 1.1rem;
            font-weight: 800;
            margin: 0;
            letter-spacing: -0.5px;
            text-transform: uppercase;
        }

        .sidebar-logo span {
            color: #3b82f6;
        }

        .sidebar-logo p {
            color: #64748b;
            font-size: 0.72rem;
            margin: 4px 0 0 0;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

    .sidebar-section {
        padding: 0 15px;
        margin-bottom: 25px;
    }

    .sidebar-section-title {
        color: #475569;
        font-size: 0.65rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        padding: 0 10px;
        margin-bottom: 8px;
    }

    .sidebar-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 11px 12px;
        border-radius: 10px;
        color: #94a3b8;
        text-decoration: none;
        font-size: 0.88rem;
        font-weight: 500;
        transition: all 0.2s ease;
        margin-bottom: 3px;
        cursor: pointer;
        border: none;
        background: transparent;
        width: 100%;
    }

        .sidebar-item:hover {
            background: rgba(255,255,255,0.07);
            color: #fff;
        }

        .sidebar-item.active {
            background: linear-gradient(135deg, #1d4ed8, #3b82f6);
            color: #fff;
            box-shadow: 0 4px 15px rgba(59,130,246,0.3);
        }

        .sidebar-item i {
            font-size: 1rem;
            width: 20px;
            text-align: center;
        }

    .sidebar-bottom {
        margin-top: auto;
        padding: 20px 15px;
        border-top: 1px solid rgba(255,255,255,0.06);
    }

    .user-info {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px;
        border-radius: 10px;
        background: rgba(255,255,255,0.05);
        margin-bottom: 10px;
    }

    .user-avatar {
        width: 36px;
        height: 36px;
        border-radius: 10px;
        background: linear-gradient(135deg, #1d4ed8, #3b82f6);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: 700;
        font-size: 0.9rem;
        flex-shrink: 0;
    }

    .user-details {
        overflow: hidden;
    }

    .user-name {
        color: #e2e8f0;
        font-size: 0.82rem;
        font-weight: 600;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .user-role {
        color: #64748b;
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .btn-logout-sidebar {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 10px 12px;
        border-radius: 10px;
        color: #ef4444;
        background: rgba(239,68,68,0.08);
        border: 1px solid rgba(239,68,68,0.15);
        text-decoration: none;
        font-size: 0.82rem;
        font-weight: 600;
        transition: all 0.2s ease;
        width: 100%;
        justify-content: center;
    }

        .btn-logout-sidebar:hover {
            background: #ef4444;
            color: white;
        }

    /* MAIN CONTENT */
    .main-content {
        margin-left: 240px;
        flex: 1;
        padding: 30px;
        min-height: 100vh;
    }

    /* TOPBAR */
    .topbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
    }

    .topbar-title h1 {
        font-size: 1.6rem;
        font-weight: 800;
        color: #0f172a;
        margin: 0;
        letter-spacing: -0.5px;
    }

    .topbar-title p {
        color: #64748b;
        font-size: 0.85rem;
        margin: 4px 0 0 0;
    }

    .btn-new-product {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 12px 22px;
        border-radius: 12px;
        background: linear-gradient(135deg, #1d4ed8, #3b82f6);
        color: white;
        font-weight: 700;
        font-size: 0.88rem;
        text-decoration: none;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(59,130,246,0.3);
        border: none;
        cursor: pointer;
    }

        .btn-new-product:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(59,130,246,0.4);
            color: white;
        }

    /* STATS GRID */
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
        margin-bottom: 30px;
    }

    .stat-card {
        background: #fff;
        border-radius: 20px;
        padding: 24px;
        border: 1px solid #f1f5f9;
        box-shadow: 0 2px 15px rgba(0,0,0,0.04);
        display: flex;
        align-items: center;
        gap: 18px;
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
    }

        .stat-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
        }

        .stat-card.blue::before {
            background: linear-gradient(90deg, #1d4ed8, #3b82f6);
        }

        .stat-card.green::before {
            background: linear-gradient(90deg, #15803d, #22c55e);
        }

        .stat-card.orange::before {
            background: linear-gradient(90deg, #c2410c, #f97316);
        }

        .stat-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 15px 35px rgba(0,0,0,0.08);
        }

    .stat-icon {
        width: 52px;
        height: 52px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.4rem;
        flex-shrink: 0;
    }

        .stat-icon.blue {
            background: #eff6ff;
            color: #1d4ed8;
        }

        .stat-icon.green {
            background: #f0fdf4;
            color: #15803d;
        }

        .stat-icon.orange {
            background: #fff7ed;
            color: #c2410c;
        }

    .stat-info h4 {
        margin: 0 0 4px 0;
        font-size: 0.72rem;
        color: #94a3b8;
        text-transform: uppercase;
        letter-spacing: 1px;
        font-weight: 600;
    }

    .stat-info p {
        margin: 0;
        font-size: 1.6rem;
        font-weight: 800;
        color: #0f172a;
        letter-spacing: -1px;
    }

    /* TABLA CARD */
    .table-card {
        background: #fff;
        border-radius: 20px;
        border: 1px solid #f1f5f9;
        box-shadow: 0 2px 15px rgba(0,0,0,0.04);
        overflow: hidden;
    }

    .table-card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 22px 25px;
        border-bottom: 1px solid #f1f5f9;
        flex-wrap: wrap;
        gap: 15px;
    }

    .table-card-title {
        font-size: 1rem;
        font-weight: 700;
        color: #0f172a;
        margin: 0;
    }

    .search-box {
        position: relative;
        min-width: 260px;
    }

        .search-box i {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: #94a3b8;
            font-size: 0.9rem;
        }

    #inputBusqueda {
        width: 100%;
        padding: 10px 14px 10px 38px;
        border-radius: 10px;
        border: 1px solid #e2e8f0;
        background: #f8fafc;
        font-family: 'Inter', sans-serif;
        font-size: 0.88rem;
        outline: none;
        transition: all 0.3s ease;
        color: #0f172a;
    }

        #inputBusqueda:focus {
            background: #fff;
            border-color: #3b82f6;
            box-shadow: 0 0 0 3px rgba(59,130,246,0.1);
        }

    /* TABLA */
    .table-wrapper {
        overflow-x: auto;
    }

    .custom-table {
        width: 100%;
        border-collapse: collapse;
        min-width: 650px;
    }

        .custom-table th {
            padding: 13px 20px;
            text-align: left;
            font-size: 0.72rem;
            font-weight: 700;
            color: #94a3b8;
            text-transform: uppercase;
            letter-spacing: 0.8px;
            background: #f8fafc;
            border-bottom: 1px solid #f1f5f9;
            white-space: nowrap;
        }

        .custom-table td {
            padding: 16px 20px;
            border-bottom: 1px solid #f8fafc;
            font-size: 0.88rem;
            vertical-align: middle;
        }

        .custom-table tbody tr {
            transition: background 0.15s ease;
        }

            .custom-table tbody tr:hover {
                background: #f8fafc;
            }

            .custom-table tbody tr:last-child td {
                border-bottom: none;
            }

    /* BADGES */
    .code-badge {
        display: inline-block;
        padding: 3px 10px;
        border-radius: 6px;
        background: #f1f5f9;
        color: #475569;
        font-size: 0.78rem;
        font-weight: 700;
        font-family: monospace;
    }

    .stock-low {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 4px 10px;
        border-radius: 20px;
        background: #fee2e2;
        color: #991b1b;
        font-weight: 700;
        font-size: 0.82rem;
        border: 1px solid #fecaca;
    }

    .stock-ok {
        font-weight: 600;
        color: #15803d;
    }

    /* BOTONES ACCION TABLA */
    .btn-action {
        padding: 7px 12px;
        border-radius: 8px;
        font-size: 0.8rem;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 5px;
        transition: all 0.2s ease;
        border: 1px solid transparent;
        white-space: nowrap;
    }

    .btn-edit {
        background: #f0fdf4;
        color: #15803d;
        border-color: #bbf7d0;
    }

        .btn-edit:hover {
            background: #15803d;
            color: white;
        }

    .btn-delete {
        background: #fff1f2;
        color: #be123c;
        border-color: #fecdd3;
    }

        .btn-delete:hover {
            background: #be123c;
            color: white;
        }

    .btn-detail {
        background: #eff6ff;
        color: #1d4ed8;
        border-color: #bfdbfe;
    }

        .btn-detail:hover {
            background: #1d4ed8;
            color: white;
        }

    /* PAGINACION */
    .pagination-container {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 18px 25px;
        border-top: 1px solid #f1f5f9;
        flex-wrap: wrap;
        gap: 10px;
    }

    .pagination-info {
        font-size: 0.82rem;
        color: #94a3b8;
    }

    .pagination-btns {
        display: flex;
        gap: 6px;
    }

    .btn-page {
        width: 36px;
        height: 36px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 9px;
        background: white;
        border: 1px solid #e2e8f0;
        color: #475569;
        text-decoration: none;
        font-weight: 600;
        font-size: 0.85rem;
        transition: all 0.2s ease;
    }

        .btn-page:hover:not(.disabled) {
            background: #3b82f6;
            color: white;
            border-color: #3b82f6;
        }

        .btn-page.active {
            background: #3b82f6;
            color: white;
            border-color: #3b82f6;
        }

        .btn-page.disabled {
            opacity: 0.35;
            cursor: not-allowed;
        }

    /* EMPTY STATE */
    .empty-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 60px 20px;
        gap: 12px;
        text-align: center;
    }

    .empty-icon {
        width: 70px;
        height: 70px;
        border-radius: 20px;
        background: #f1f5f9;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #cbd5e1;
        font-size: 1.8rem;
        margin-bottom: 5px;
    }

    .empty-state h3 {
        margin: 0;
        font-size: 1rem;
        font-weight: 700;
        color: #334155;
    }

    .empty-state p {
        margin: 4px 0 0 0;
        color: #94a3b8;
        font-size: 0.88rem;
    }

    /* ── RESPONSIVE ── */

    /* Botón hamburguesa (solo móvil) */
    .mobile-topbar {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        height: 62px;
        background: rgba(240, 244, 248, 0.85);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid rgba(255,255,255,0.6);
        z-index: 250;
        align-items: center;
        padding: 0 16px;
    }

    .menu-toggle {
        width: 42px;
        height: 42px;
        border-radius: 12px;
        background: #0f172a;
        border: none;
        color: white;
        font-size: 1.1rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 15px rgba(0,0,0,0.2);
        transition: opacity 0.2s ease;
        flex-shrink: 0;
    }

    @@media (max-width: 767px) {
        .mobile-topbar {
            display: flex;
        }

        .main-content,
        .main-wrapper {
            margin-left: 0 !important;
            width: 100% !important;
            padding: 16px;
            padding-top: 78px; /* altura barra + espacio */
        }
    }

    .sidebar-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.5);
        z-index: 150;
    }

    /* TABLET (768px - 1024px) */
    @@media (max-width: 1024px) {
        .sidebar {
            width: 70px;
        }

        .sidebar-logo h2, .sidebar-logo p,
        .sidebar-section-title, .sidebar-item span,
        .user-details, .btn-logout-sidebar span {
            display: none;
        }

        .sidebar-item {
            justify-content: center;
            padding: 12px;
        }

        .user-info {
            justify-content: center;
        }

        .user-avatar {
            margin: 0;
        }

        .btn-logout-sidebar {
            justify-content: center;
        }

        .main-content {
            margin-left: 70px;
        }

        .stats-grid {
            grid-template-columns: 1fr 1fr;
        }

        .topbar {
            flex-wrap: wrap;
            gap: 12px;
        }
    }

    @@media (max-width: 767px) {
        .menu-toggle {
            display: flex;
        }

        .sidebar {
            transform: translateX(-100%); /* ← oculto por defecto en móvil */
            width: 240px;
            /* Restaura todo lo que el media de tablet ocultó */
        }

            .sidebar.open {
                transform: translateX(0);
            }
        /* Restaurar textos del sidebar que el breakpoint tablet ocultó */
        .sidebar-logo h2,
        .sidebar-logo p,
        .sidebar-section-title,
        .sidebar-item span,
        .user-details,
        .btn-logout-sidebar span {
            display: block !important;
        }

        .sidebar-item {
            justify-content: flex-start !important;
            padding: 11px 12px !important;
        }

        .user-info {
            justify-content: flex-start !important;
        }

        .btn-logout-sidebar {
            justify-content: center;
        }

        .sidebar-overlay.open {
            display: block;
        }

        .main-content {
            margin-left: 0;
            padding: 20px 15px;
            padding-top: 70px;
        }

        .stats-grid {
            grid-template-columns: 1fr;
            gap: 14px;
        }

        .topbar {
            flex-direction: column;
            align-items: flex-start;
            gap: 14px;
            padding-top: 10px;
        }

        .topbar-title h1 {
            font-size: 1.3rem;
        }

        .btn-new-product {
            width: 100%;
            justify-content: center;
        }

        .table-card-header {
            position: relative;
            z-index: 1; /* menor que el botón hamburguesa */
        }

        .topbar-title h1 {
            font-size: 1.3rem;
        }

        .topbar {
            padding-top: 5px;
        }
        /* Stat cards no se solapan */
        .stat-card {
            padding: 18px;
        }

        .stat-info p {
            font-size: 1.3rem;
        }
        /* Botones de acción en tabla móvil no se cortan */
        .product-card-actions .btn-action {
            font-size: 0.78rem;
            padding: 8px 10px;
        }

        .search-box {
            min-width: unset;
            width: 100%;
        }

        #inputBusqueda {
            width: 100%;
        }
        /* Ocultar tabla, mostrar tarjetas */
        .table-wrapper {
            display: none;
        }

        .product-cards {
            display: flex;
            flex-direction: column;
            gap: 12px;
            padding: 15px;
        }

        .product-card {
            background: #fff;
            border: 1px solid #f1f5f9;
            border-radius: 16px;
            padding: 16px;
        }

        .product-card-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 8px 0;
            border-bottom: 1px solid #f8fafc;
            font-size: 0.88rem;
            gap: 10px;
        }

            .product-card-row:last-of-type {
                border-bottom: none;
            }

        .product-card-label {
            font-size: 0.68rem;
            color: #94a3b8;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            flex-shrink: 0;
        }

        .product-card-value {
            font-weight: 600;
            color: #0f172a;
            text-align: right;
        }

        .product-card-actions {
            display: flex;
            gap: 8px;
            margin-top: 12px;
            flex-wrap: wrap;
        }

            .product-card-actions .btn-action {
                flex: 1;
                justify-content: center;
                min-width: 80px;
            }

        .pagination-container {
            flex-direction: column;
            align-items: center;
            gap: 12px;
        }
    }

    @@media (min-width: 768px) {
        .product-cards {
            display: none;
        }
    }
</style>
<!-- Botón hamburguesa -->
<div class="mobile-topbar">
    <button class="menu-toggle" id="menuToggle">
        <i class="bi bi-list" id="menuIcon"></i>
    </button>
</div>
<div class="sidebar-overlay" id="sidebarOverlay"></div>
<div class="app-layout">

    <!-- SIDEBAR -->
    <aside class="sidebar">
        <div class="sidebar-logo">
            <h2>Becarios<span>BD</span></h2>
            <p>Panel de Control</p>
        </div>

        <div class="sidebar-section">
            <p class="sidebar-section-title">Principal</p>
            <a class="sidebar-item active" href="#">
                <i class="bi bi-grid-1x2-fill"></i>
                <span>Productos</span>
            </a>
            @if (User.IsInRole("Admin"))
            {
                <a class="sidebar-item" asp-page="/Usuarios/Index">
                    <i class="bi bi-people-fill"></i>
                    <span>Usuarios</span>
                </a>
                <a class="sidebar-item" asp-page="./Historial">
                    <i class="bi bi-clock-history"></i>
                    <span>Historial</span>
                </a>
            }
        </div>

        <div class="sidebar-section">
            <p class="sidebar-section-title">Herramientas</p>
            <a class="sidebar-item" asp-page="Importar">
                <i class="bi bi-file-earmark-arrow-up"></i>
                <span>Importar CSV</span>
            </a>
            <a class="sidebar-item" asp-page="Crear">
                <i class="bi bi-plus-circle"></i>
                <span>Nuevo Producto</span>
            </a>
        </div>

        <div class="sidebar-bottom">
            <div class="user-info">
                <div class="user-avatar">
                    @User.Identity.Name?.Substring(0, 1).ToUpper()
                </div>
                <div class="user-details">
                    <div class="user-name">@User.Identity.Name</div>
                    <div class="user-role">@(User.IsInRole("Admin") ? "Administrador" : "Usuario")</div>
                </div>
            </div>
            <a asp-page="/Index" asp-page-handler="Logout" class="btn-logout-sidebar">
                <i class="bi bi-box-arrow-right"></i>
                <span>Cerrar Sesion</span>
            </a>
        </div>
    </aside>

    <!-- CONTENIDO PRINCIPAL -->
    <main class="main-content">

        <!-- TOPBAR -->
        <div class="topbar">
            <div class="topbar-title">
                <h1>Inventario de Productos</h1>
                <p>Gestion y control del catalogo de productos</p>
            </div>
            <a class="btn-new-product" asp-page="Crear">
                <i class="bi bi-plus-lg"></i> Nuevo Producto
            </a>
        </div>

        <!-- STATS -->
        <div class="stats-grid">
            <div class="stat-card blue">
                <div class="stat-icon blue"><i class="bi bi-boxes"></i></div>
                <div class="stat-info">
                    <h4>Total Productos</h4>
                    <p>@Model.TotalProductos</p>
                </div>
            </div>
            <div class="stat-card green">
                <div class="stat-icon green"><i class="bi bi-currency-dollar"></i></div>
                <div class="stat-info">
                    <h4>Valor Inventario</h4>
                    <p>@Model.ValorInventario.ToString("N0")$</p>
                </div>
            </div>
            <div class="stat-card orange">
                <div class="stat-icon orange"><i class="bi bi-exclamation-triangle"></i></div>
                <div class="stat-info">
                    <h4>Stock Critico</h4>
                    <p>@Model.StockBajoCount</p>
                </div>
            </div>
        </div>

        <!-- TABLA -->
        <div class="table-card">
            <div class="table-card-header">
                <h3 class="table-card-title">
                    <i class="bi bi-table" style="color:#3b82f6;margin-right:8px;"></i>
                    Lista de Productos
                </h3>
                <form method="get" id="formFiltros">
                    <div class="search-box">
                        <i class="bi bi-search"></i>
                        <input type="text" name="buscar" id="inputBusqueda"
                               placeholder="Buscar producto..."
                               value="@Model.FiltroActual" autocomplete="off">
                    </div>
                </form>
            </div>

            <div class="table-wrapper">
                <table class="custom-table">
                    <thead>
                        <tr>
                            <th>Codigo</th>
                            <th>Nombre</th>
                            <th>Creador</th>
                            <th>Precio</th>
                            <th>Stock</th>
                            <th>Registro</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            var currentUserId = User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
                        }
                        @if (Model.productos.Any())
                        {
                            @foreach (var producto in Model.productos)
                            {
                                <tr>
                                    <td><span class="code-badge">@producto.CodigoProducto</span></td>
                                    <td style="font-weight:600;color:#0f172a;">@producto.Nombre</td>
                                    <td>
                                        <div style="display:flex;align-items:center;gap:8px;">
                                            <div style="width:28px;height:28px;border-radius:8px;background:linear-gradient(135deg,#1d4ed8,#3b82f6);display:flex;align-items:center;justify-content:center;color:white;font-size:0.72rem;font-weight:700;flex-shrink:0;">
                                                @(producto.Creador?.Nombre?.Substring(0, 1).ToUpper() ?? "A")
                                            </div>
                                            <span style="font-weight:500;color:#334155;">@(producto.Creador?.Nombre?.Trim() ?? "Admin")</span>
                                        </div>
                                    </td>
                                    <td style="font-weight:700;color:#0f172a;">$@producto.Precio.ToString("N2")</td>
                                    <td>
                                        @if (producto.Stock < 10)
                                        {
                                            <span class="stock-low">
                                                <i class="bi bi-exclamation-circle-fill"></i> @producto.Stock
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="stock-ok">@producto.Stock</span>
                                        }
                                    </td>
                                    <td style="color:#94a3b8;font-size:0.82rem;">@producto.FechaCreacion.ToShortDateString()</td>
                                    <td>
                                        <div style="display:flex;flex-direction:row;gap:6px;align-items:center;flex-wrap:nowrap;">
                                            @if (currentUserId == producto.UsuarioId.ToString() || User.IsInRole("Admin"))
                                            {
                                                <a class="btn-action btn-edit" asp-page="Editar" asp-route-id="@producto.Id">
                                                    <i class="bi bi-pencil-square"></i> Editar
                                                </a>
                                                <a class="btn-action btn-delete" asp-page="Borrar" asp-route-id="@producto.Id">
                                                    <i class="bi bi-trash3"></i> Borrar
                                                </a>
                                            }
                                            <a class="btn-action btn-detail" asp-page="Detalle" asp-route-id="@producto.Id">
                                                <i class="bi bi-eye"></i> Ver
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7">
                                    <div class="empty-state">
                                        <div class="empty-icon"><i class="bi bi-search"></i></div>
                                        <h3>Sin resultados</h3>
                                        <p>No hay productos que coincidan con tu busqueda.</p>
                                        <a asp-page="./Inicio" style="color:#3b82f6;font-weight:600;font-size:0.88rem;text-decoration:none;">
                                            Limpiar filtros
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- TARJETAS MOVIL -->
            <div class="product-cards">
                @if (Model.productos.Any())
                {
                    @foreach (var producto in Model.productos)
                    {
                        <div class="product-card">
                            <div class="product-card-row">
                                <span class="product-card-label">Codigo</span>
                                <span class="product-card-value"><span class="code-badge">@producto.CodigoProducto</span></span>
                            </div>
                            <div class="product-card-row">
                                <span class="product-card-label">Nombre</span>
                                <span class="product-card-value">@producto.Nombre</span>
                            </div>
                            <div class="product-card-row">
                                <span class="product-card-label">Precio</span>
                                <span class="product-card-value">$@producto.Precio.ToString("N2")</span>
                            </div>
                            <div class="product-card-row">
                                <span class="product-card-label">Stock</span>
                                <span class="product-card-value">
                                    @if (producto.Stock < 10)
                                    {
                                        <span class="stock-low"><i class="bi bi-exclamation-circle-fill"></i> @producto.Stock</span>
                                    }
                                    else
                                    {
                                        <span class="stock-ok">@producto.Stock</span>
                                    }
                                </span>
                            </div>
                            <div class="product-card-actions">
                                @if (currentUserId == producto.UsuarioId.ToString() || User.IsInRole("Admin"))
                                {
                                    <a class="btn-action btn-edit" asp-page="Editar" asp-route-id="@producto.Id">
                                        <i class="bi bi-pencil-square"></i> Editar
                                    </a>
                                    <a class="btn-action btn-delete" asp-page="Borrar" asp-route-id="@producto.Id">
                                        <i class="bi bi-trash3"></i> Borrar
                                    </a>
                                }
                                <a class="btn-action btn-detail" asp-page="Detalle" asp-route-id="@producto.Id">
                                    <i class="bi bi-eye"></i> Ver
                                </a>
                            </div>
                        </div>
                    }
                }
            </div>

            <!-- PAGINACION -->
            @if (Model.TotalPaginas > 1)
            {
                <div class="pagination-container">
                    <span class="pagination-info">
                        Pagina <strong>@Model.PaginaActual</strong> de <strong>@Model.TotalPaginas</strong>
                        &nbsp;&middot;&nbsp; @Model.TotalProductos registros
                    </span>
                    <div class="pagination-btns">
                        @if (Model.PaginaActual > 1)
                        {
                            <a asp-page="./Inicio" asp-route-pagina="@(Model.PaginaActual - 1)"
                               asp-route-buscar="@Model.FiltroActual" class="btn-page">
                                <i class="bi bi-chevron-left"></i>
                            </a>
                        }
                        else
                        {
                            <span class="btn-page disabled"><i class="bi bi-chevron-left"></i></span>
                        }

                        @if (Model.PaginaActual < Model.TotalPaginas)
                        {
                            <a asp-page="./Inicio" asp-route-pagina="@(Model.PaginaActual + 1)"
                               asp-route-buscar="@Model.FiltroActual" class="btn-page">
                                <i class="bi bi-chevron-right"></i>
                            </a>
                        }
                        else
                        {
                            <span class="btn-page disabled"><i class="bi bi-chevron-right"></i></span>
                        }
                    </div>
                </div>
            }
        </div>
    </main>
</div>

<script>
    let timer;
    const inputBusqueda = document.getElementById('inputBusqueda');
    const formFiltros = document.getElementById('formFiltros');

    inputBusqueda.addEventListener('input', function () {
        clearTimeout(timer);
        timer = setTimeout(() => { formFiltros.submit(); }, 500);
    });

    if (inputBusqueda.value.length > 0) {
        inputBusqueda.focus();
        inputBusqueda.setSelectionRange(inputBusqueda.value.length, inputBusqueda.value.length);
    }

    document.addEventListener("DOMContentLoaded", function () {
        var mensaje = '@TempData["Mensaje"]';
        var tipo = '@TempData["Tipo"]';
        if (mensaje && mensaje !== '') {
            const Toast = Swal.mixin({
                toast: true, position: 'top-end',
                showConfirmButton: false, timer: 3000, timerProgressBar: true
            });
            Toast.fire({ icon: tipo || 'success', title: mensaje });
        }
    });
</script>
<script>
    document.addEventListener('DOMContentLoaded', function () {
        const menuToggle  = document.getElementById('menuToggle');
        const menuIcon    = document.getElementById('menuIcon');
        const sidebar     = document.querySelector('.sidebar');
        const overlay     = document.getElementById('sidebarOverlay');
        const mobileTopbar = document.querySelector('.mobile-topbar'); // ← barra entera

        function openSidebar() {
            sidebar.classList.add('open');
            overlay.classList.add('open');
            document.body.style.overflow = 'hidden';
            menuIcon.classList.replace('bi-list', 'bi-x-lg');
            mobileTopbar.style.display = 'none'; // ← oculta la barra completa
        }

        function closeSidebar() {
            sidebar.classList.remove('open');
            overlay.classList.remove('open');
            document.body.style.overflow = '';
            menuIcon.classList.replace('bi-x-lg', 'bi-list');
            mobileTopbar.style.display = 'flex'; // ← vuelve a mostrarla
        }

        menuToggle?.addEventListener('click', () => {
            sidebar.classList.contains('open') ? closeSidebar() : openSidebar();
        });
        overlay?.addEventListener('click', closeSidebar);
        sidebar?.querySelectorAll('.sidebar-item').forEach(item => {
            item.addEventListener('click', () => {
                if (window.innerWidth < 768) closeSidebar();
            });
        });
        document.addEventListener('keydown', e => {
            if (e.key === 'Escape') closeSidebar();
        });
    });
</script>