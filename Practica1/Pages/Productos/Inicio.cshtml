@page
@model Practica1.Pages.Productos.InicioModel
@using System.Security.Claims
@{
    ViewData["Title"] = "Panel de Control - BecariosBD";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<style>
    nav, .navbar, footer, header:not(.header-home) {
        display: none !important;
    }

    body {
        margin: 0;
        padding: 0;
        width: 100%;
        min-height: 100vh;
        font-family: 'Inter', sans-serif;
        background-color: #fcfcfc;
        color: #333;
    }

    .main-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 40px 15px;
    }

    .glass-card {
        background: #ffffff;
        padding: 35px 25px;
        border-radius: 30px;
        width: 100%;
        max-width: 1200px;
        box-shadow: 0 20px 60px rgba(0,0,0,0.08);
        border: 1px solid #f0f0f0;
        position: relative;
        box-sizing: border-box;
    }

    h1 {
        margin: 0 0 10px 0;
        text-align: center;
        font-weight: 800;
        letter-spacing: -1px;
        font-size: clamp(1.6rem, 4vw, 2.8rem);
        text-transform: uppercase;
        color: #1a1a1a;
        /* Dejar espacio para el botón logout en pantallas medias */
        padding: 0 130px;
    }

    .welcome-user {
        text-align: center;
        margin-bottom: 30px;
        font-size: 1rem;
        color: #666;
        font-weight: 400;
    }

        .welcome-user strong {
            color: #1976d2;
            font-weight: 600;
            border-bottom: 2px solid #e3f2fd;
        }


    /* LOGOUT */
    .logout-container {
        position: absolute;
        top: 20px;
        right: 20px;
    }

    .btn-logout {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 8px 14px;
        background-color: #fff5f5;
        color: #d32f2f;
        border: 1px solid #ff00001a;
        text-decoration: none;
        font-weight: 700;
        font-size: 0.8rem;
        text-transform: uppercase;
        border-radius: 10px;
        transition: all 0.3s ease;
        white-space: nowrap;
    }

        .btn-logout:hover {
            background-color: #d32f2f;
            color: #fff;
            transform: translateY(-2px);
        }

        .btn-logout .logout-text {
            display: inline;
        }

    /* ACTIONS BAR */
    .actions-bar {
        display: flex;
        flex-wrap: wrap;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 25px;
        gap: 12px;
    }

    .filters-group {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        flex-grow: 1;
        min-width: 0;
    }

    .search-wrapper {
        position: relative;
        flex: 1;
        min-width: 180px;
    }

        .search-wrapper i {
            position: absolute;
            left: 15px;
            top: 50%;
            transform: translateY(-50%);
            color: #aaa;
            font-size: 1rem;
        }

    #inputBusqueda {
        width: 100%;
        padding: 13px 13px 13px 42px;
        border-radius: 15px;
        border: 1px solid #eee;
        background: #f9f9f9;
        font-family: 'Inter', sans-serif;
        font-size: 0.9rem;
        outline: none;
        transition: all 0.3s ease;
        box-sizing: border-box;
    }

        #inputBusqueda:focus {
            background: #fff;
            border-color: #1976d2;
            box-shadow: 0 8px 20px rgba(0,0,0,0.05);
        }

    .btn-add-cyber {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 13px 20px;
        border-radius: 13px;
        background: #1b5e20;
        color: #fff;
        font-weight: 700;
        text-transform: uppercase;
        text-decoration: none;
        transition: all 0.3s ease;
        box-shadow: 0 8px 20px rgba(27,94,32,0.15);
        white-space: nowrap;
        font-size: 0.85rem;
    }

        .btn-add-cyber:hover {
            transform: translateY(-2px);
            background: #2e7d32;
            color: white;
        }

    /* TABLA */
    .table-wrapper {
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
    }

    .custom-table {
        width: 100%;
        border-collapse: collapse;
        min-width: 600px;
    }

        .custom-table th {
            text-align: left;
            padding: 15px 12px;
            color: darkred;
            font-weight: 800;
            text-transform: uppercase;
            font-size: 0.78rem;
            border-bottom: 2px solid #f0f0f0;
            white-space: nowrap;
        }

        .custom-table td {
            padding: 15px 12px;
            border-bottom: 1px solid #f8f8f8;
            font-size: 0.9rem;
        }

    .btn-action {
        padding: 8px 11px;
        border-radius: 8px;
        font-size: 0.82rem;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 5px;
        transition: all 0.2s ease;
        margin-right: 5px;
        margin-bottom: 4px;
        border: 1px solid #eee;
        white-space: nowrap;
    }

    .btn-edit {
        background: #fff;
        color: #1b5e20;
        border-color: #c8e6c9;
    }

        .btn-edit:hover {
            background: #1b5e20;
            color: white;
        }

    .btn-delete {
        background: #fff;
        color: #d32f2f;
        border-color: #ffcdd2;
    }

        .btn-delete:hover {
            background: #d32f2f;
            color: white;
        }

    .btn-detail {
        background: #fff;
        color: #1976d2;
        border-color: #bbdefb;
    }

        .btn-detail:hover {
            background: #1976d2;
            color: white;
        }

    /* PAGINACIÓN */
    .pagination-container {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 8px;
        margin-top: 25px;
        flex-wrap: wrap;
    }

    .btn-page {
        width: 38px;
        height: 38px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 10px;
        background: white;
        border: 1px solid #eee;
        color: #333;
        text-decoration: none;
        font-weight: 600;
        transition: all 0.2s ease;
    }

        .btn-page:hover:not(.disabled) {
            background: #1976d2;
            color: white;
            transform: translateY(-2px);
        }

        .btn-page.active {
            background: #1976d2;
            color: white;
            border-color: #1976d2;
        }

        .btn-page.disabled {
            opacity: 0.4;
            cursor: not-allowed;
            background: #f5f5f5;
        }

    .page-info {
        font-size: 0.85rem;
        color: #777;
        margin: 0 5px;
    }

    /* EMPTY STATE */
    .empty-state-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 40px 0;
        gap: 12px;
    }

    .empty-icon-circle {
        background: #f8f9fa;
        width: 70px;
        height: 70px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #adb5bd;
        margin-bottom: 8px;
    }

    /* SUMMARY */
    .summary-outer-container {
        width: 100%;
        max-width: 1200px;
        margin-top: 25px;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 15px;
        box-sizing: border-box;
    }

    .summary-card {
        background: #fff;
        padding: 20px;
        border-radius: 20px;
        border: 1px solid #f0f0f0;
        display: flex;
        align-items: center;
        gap: 15px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.02);
        transition: all 0.3s cubic-bezier(0.4,0,0.2,1);
    }

        .summary-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 15px 35px rgba(0,0,0,0.06);
            border-color: #e0e0e0;
        }

        .summary-card i {
            font-size: 1.6rem;
            width: 50px;
            height: 50px;
            min-width: 50px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 13px;
        }

    .bg-blue {
        background: #e3f2fd;
        color: #1976d2;
    }

    .bg-green {
        background: #e8f5e9;
        color: #2e7d32;
    }

    .bg-orange {
        background: #fff3e0;
        color: #ef6c00;
    }

    .summary-info h4 {
        margin: 0;
        font-size: 0.7rem;
        color: #999;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .summary-info p {
        margin: 0;
        font-size: 1.3rem;
        font-weight: 800;
        color: #333;
    }

    /*RESPONSIVE*/
    @@media (max-width: 991px) {
        h1

    {
        padding: 0 100px; 
        font-size: clamp(1.2rem, 3.5vw, 2rem);
    }

    .btn-logout {
        font-size: 0.75rem;
        padding: 7px 10px;
    }

        .btn-logout .logout-text {
            display: none;
        }

    }

    @@media (max-width: 768px) {
        h1

    {
        padding: 0;
        font-size: clamp(1.4rem, 5vw, 2rem);
    }

    .logout-container {
        position: static;
        margin-bottom: 15px;
        display: flex;
        justify-content: flex-end;
    }

    .btn-logout .logout-text {
        display: none;
    }

    }

    @@media (max-width: 768px) {
        .glass-card

    {
        padding: 25px 15px;
        border-radius: 20px;
    }

    .logout-container {
        position: static;
        margin-bottom: 15px;
        display: flex;
        justify-content: flex-end;
    }

    .actions-bar {
        flex-direction: column;
        align-items: stretch;
    }

    .filters-group {
        flex-direction: column;
    }

    .btn-add-cyber {
        justify-content: center;
    }

    /* OCULTAR TABLA NORMAL */
    .table-wrapper {
        display: none;
    }

    /* TARJETAS DE PRODUCTO */
    .product-cards {
        display: flex;
        flex-direction: column;
        gap: 15px;
    }

    .product-card {
        background: #fff;
        border: 1px solid #f0f0f0;
        border-radius: 18px;
        padding: 20px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
    }

    .product-card-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        padding: 10px 0;
        border-bottom: 1px solid #f5f5f5;
        align-items: center;
        gap: 8px;
    }

        .product-card-row:last-child {
            border-bottom: none;
        }

    .product-card-label {
        font-size: 0.72rem;
        color: darkred;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1.5px;
    }

    .product-card-value {
        font-size: 0.9rem;
        font-weight: 600;
        color: #1a1a1a;
        text-align: right;
    }

    .product-card-actions {
        display: flex;
        gap: 8px;
        margin-top: 15px;
        flex-wrap: wrap;
    }

        .product-card-actions .btn-action {
            flex: 1;
            justify-content: center;
            min-width: 80px;
        }

    }

    @@media (min-width: 769px) {
        .product-cards

    {
        display: none;
    }

    }

    @@media (max-width: 480px) {
        .main-container

    {
        padding: 20px 10px;
    }

    .summary-outer-container {
        grid-template-columns: 1fr;
    }

    }
</style>

<div class="main-container">
    <div class="glass-card">
        <div class="logout-container">
            <a asp-page="/Index" asp-page-handler="Logout" class="btn-logout">
                <i class="bi bi-box-arrow-right"></i>
                <span class="logout-text">Cerrar Sesión</span>
            </a>
        </div>

        <h1>Base de Datos Becarios</h1>
        <div class="welcome-user">
            <i class="bi bi-person-circle"></i> Sesión iniciada como: <strong>@User.Identity.Name</strong>
        </div>

        <div class="actions-bar">
            <form method="get" class="filters-group" id="formFiltros">
                <div class="search-wrapper">
                    <i class="bi bi-search"></i>
                    <input type="text" name="buscar" id="inputBusqueda"
                           placeholder="Buscar producto..."
                           value="@Model.FiltroActual" autocomplete="off">
                </div>
            </form>

            <a class="btn-add-cyber" asp-page="Importar" style="background: #1565c0;">
                <i class="bi bi-file-earmark-arrow-up"></i>
                <span>Importar CSV</span>
            </a>
            <a class="btn-add-cyber" asp-page="Crear">
                <i class="bi bi-plus-circle-dotted"></i>
                <span>Nuevo Producto</span>
            </a>
        </div>

        @if (User.IsInRole("Admin"))
        {
            <div style="margin-bottom: 20px;">
                <a asp-page="/Usuarios/Index" class="btn-action btn-detail" style="border-color: #1976d2; color: #1976d2;">
                    <i class="bi bi-people"></i> <span class="btn-text">Gestionar Usuarios</span>
                </a>

                <!-- AÑADIR ESTO -->
                <a asp-page="./Historial" class="btn-action btn-detail" style="border-color:#e0e0e0;color:#555;">
                    <i class="bi bi-clock-history"></i> Ver Historial
                </a>
            </div>
        }

        <div class="table-wrapper">
            <table class="custom-table" id="tablaProductos">
                <thead>
                    <tr>
                        <th>Código</th>
                        <th>Nombre</th>
                        <th>Creador</th>
                        <th>Precio</th>
                        <th>Stock</th>
                        <th>Registro</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        var currentUserId = User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
                    }

                    @if (Model.productos.Any())
                    {
                        @foreach (var producto in Model.productos)
                        {
                            <tr>
                                <td style="font-weight:600;color:#666;font-size:0.85rem;">@producto.CodigoProducto</td>
                                <td style="font-weight:600;color:#1a1a1a;">@producto.Nombre</td>
                                <td style="font-weight:500;color:#1976d2;">
                                    <i class="bi bi-person"></i> @(producto.Creador?.Nombre?.Trim() ?? "Admin")
                                </td>
                                <td style="font-weight:500;">$@producto.Precio.ToString("N2")</td>
                                <td>
                                    @if (producto.Stock < 10)
                                    {
                                        <span style="display:inline-flex;align-items:center;gap:4px;padding:4px 10px;border-radius:20px;background:#fee2e2;color:#991b1b;font-weight:800;font-size:0.85rem;border:1px solid #fecaca;">
                                            <i class="bi bi-exclamation-circle-fill"></i> @producto.Stock
                                        </span>
                                    }
                                    else
                                    {
                                        <span style="font-weight:600;color:#1b5e20;">@producto.Stock</span>
                                    }
                                </td>
                                <td style="font-size:0.82rem;color:#666;white-space:nowrap;">@producto.FechaCreacion.ToShortDateString()</td>
                                <td style="white-space:nowrap;">
                                    @if (currentUserId == producto.UsuarioId.ToString() || User.IsInRole("Admin"))
                                    {
                                        <a class="btn-action btn-edit" asp-page="Editar" asp-route-id="@producto.Id">
                                            <i class="bi bi-pencil-square"></i><span class="btn-text"> Editar</span>
                                        </a>
                                        <a class="btn-action btn-delete" asp-page="Borrar" asp-route-id="@producto.Id">
                                            <i class="bi bi-trash3"></i><span class="btn-text"> Borrar</span>
                                        </a>
                                    }
                                    <a class="btn-action btn-detail" asp-page="Detalle" asp-route-id="@producto.Id">
                                        <i class="bi bi-eye"></i><span class="btn-text"> Detalle</span>
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7">
                                <div class="empty-state-container">
                                    <div class="empty-icon-circle">
                                        <i class="bi bi-search" style="font-size:2rem;"></i>
                                    </div>
                                    <div style="text-align:center;">
                                        <h3 style="margin:0;font-weight:700;color:#343a40;">No se encontraron productos</h3>
                                        <p style="margin:5px 0 0 0;color:#6c757d;">No hay coincidencias en la base de datos.</p>
                                    </div>
                                    <a asp-page="./Inicio" style="color:#1976d2;font-weight:600;text-decoration:underline;">
                                        Limpiar filtros y ver todos
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- TARJETAS MÓVIL -->
        <div class="product-cards">
            @if (Model.productos.Any())
            {
                @foreach (var producto in Model.productos)
                {
                    <div class="product-card">
                        <div class="product-card-row">
                            <span class="product-card-label">Código</span>
                            <span class="product-card-value" style="color:#666;">@producto.CodigoProducto</span>
                        </div>
                        <div class="product-card-row">
                            <span class="product-card-label">Nombre</span>
                            <span class="product-card-value">@producto.Nombre</span>
                        </div>
                        <div class="product-card-row">
                            <span class="product-card-label">Creador</span>
                            <span class="product-card-value" style="color:#1976d2;">
                                <i class="bi bi-person"></i> @(producto.Creador?.Nombre?.Trim() ?? "Admin")
                            </span>
                        </div>
                        <div class="product-card-row">
                            <span class="product-card-label">Precio</span>
                            <span class="product-card-value">$@producto.Precio.ToString("N2")</span>
                        </div>
                        <div class="product-card-row">
                            <span class="product-card-label">Stock</span>
                            <span class="product-card-value">
                                @if (producto.Stock < 10)
                                {
                                    <span style="display:inline-flex;align-items:center;gap:4px;padding:3px 10px;border-radius:20px;background:#fee2e2;color:#991b1b;font-weight:800;font-size:0.85rem;border:1px solid #fecaca;">
                                        <i class="bi bi-exclamation-circle-fill"></i> @producto.Stock
                                    </span>
                                }
                                else
                                {
                                    <span style="color:#1b5e20;">@producto.Stock</span>
                                }
                            </span>
                        </div>
                        <div class="product-card-row">
                            <span class="product-card-label">Registro</span>
                            <span class="product-card-value" style="color:#666;font-size:0.85rem;">@producto.FechaCreacion.ToShortDateString()</span>
                        </div>

                        <div class="product-card-actions">
                            @if (currentUserId == producto.UsuarioId.ToString() || User.IsInRole("Admin"))
                            {
                                <a class="btn-action btn-edit" asp-page="Editar" asp-route-id="@producto.Id">
                                    <i class="bi bi-pencil-square"></i> Editar
                                </a>
                                <a class="btn-action btn-delete" asp-page="Borrar" asp-route-id="@producto.Id">
                                    <i class="bi bi-trash3"></i> Borrar
                                </a>
                            }
                            <a class="btn-action btn-detail" asp-page="Detalle" asp-route-id="@producto.Id">
                                <i class="bi bi-eye"></i> Detalle
                            </a>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="product-card" style="text-align:center;padding:40px 20px;">
                    <i class="bi bi-search" style="font-size:2rem;color:#adb5bd;display:block;margin-bottom:10px;"></i>
                    <h3 style="margin:0;font-weight:700;color:#343a40;">No se encontraron productos</h3>
                    <p style="color:#6c757d;margin:5px 0 10px 0;">No hay coincidencias en la base de datos.</p>
                    <a asp-page="./Inicio" style="color:#1976d2;font-weight:600;text-decoration:underline;">Limpiar filtros</a>
                </div>
            }
        </div>

        @if (Model.TotalPaginas > 1)
        {
            <div class="pagination-container">
                @if (Model.PaginaActual > 1)
                {
                    <a asp-page="./Inicio" asp-route-pagina="@(Model.PaginaActual - 1)"
                       asp-route-buscar="@Model.FiltroActual"
                       asp-route-usuarioId="@Model.UsuarioSeleccionadoId" class="btn-page">
                        <i class="bi bi-chevron-left"></i>
                    </a>
                }
                else
                {

                    <span class="btn-page disabled"><i class="bi bi-chevron-left"></i></span>
                }

                <span class="page-info">Página <strong>@Model.PaginaActual</strong> de @Model.TotalPaginas</span>

                @if (Model.PaginaActual < Model.TotalPaginas)
                {
                    <a asp-page="./Inicio" asp-route-pagina="@(Model.PaginaActual + 1)"
                       asp-route-buscar="@Model.FiltroActual"
                       asp-route-usuarioId="@Model.UsuarioSeleccionadoId" class="btn-page">
                        <i class="bi bi-chevron-right"></i>
                    </a>
                }
                else
                {

                    <span class="btn-page disabled"><i class="bi bi-chevron-right"></i></span>
                }
            </div>
        }
    </div>

    <div class="summary-outer-container">
        <div class="summary-card">
            <i class="bi bi-boxes bg-blue"></i>
            <div class="summary-info"><h4>Total Productos</h4><p>@Model.TotalProductos</p></div>
        </div>
        <div class="summary-card">
            <i class="bi bi-currency-dollar bg-green"></i>
            <div class="summary-info"><h4>Valor Inventario</h4><p>@Model.ValorInventario.ToString("N2")$</p></div>
        </div>
        <div class="summary-card">
            <i class="bi bi-exclamation-triangle bg-orange"></i>
            <div class="summary-info"><h4>Stock Crítico (< 10)</h4><p>@Model.StockBajoCount</p></div>
        </div>
    </div>
</div>

<script>
    let timer;
    const inputBusqueda = document.getElementById('inputBusqueda');
    const formFiltros = document.getElementById('formFiltros');

    inputBusqueda.addEventListener('input', function () {
        clearTimeout(timer);
        timer = setTimeout(() => { formFiltros.submit(); }, 500);
    });

    if (inputBusqueda.value.length > 0) {
        inputBusqueda.focus();
        inputBusqueda.setSelectionRange(inputBusqueda.value.length, inputBusqueda.value.length);
    }

    document.addEventListener("DOMContentLoaded", function () {
        var mensaje = '@TempData["Mensaje"]';
        var tipo = '@TempData["Tipo"]';
        if (mensaje && mensaje !== '') {
            const Toast = Swal.mixin({
                toast: true, position: 'top-end',
                showConfirmButton: false, timer: 3000, timerProgressBar: true
            });
            Toast.fire({ icon: tipo || 'success', title: mensaje });
        }
    });
</script>