@page
@model Practica1.Pages.Productos.ImportarModel
@{
    ViewData["Title"] = "Importar Productos - BecariosBD";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

<style>
    nav, .navbar, footer, header:not(.header-home) {
        display: none !important;
    }

    *, *::before, *::after {
        box-sizing: border-box;
    }

    body {
        margin: 0;
        padding: 0;
        width: 100%;
        min-height: 100vh;
        font-family: 'Inter', sans-serif;
        background: linear-gradient(135deg, #f0f4f8 0%, #e8edf2 100%);
        color: #1a1a2e;
    }

    .app-layout {
        display: flex;
        min-height: 100vh;
    }

    .sidebar {
        width: 240px;
        min-height: 100vh;
        background: #0f172a;
        display: flex;
        flex-direction: column;
        padding: 30px 0;
        position: fixed;
        top: 0;
        left: 0;
        z-index: 100;
        transition: width 0.3s ease;
    }

    .sidebar-logo {
        padding: 0 25px 30px 25px;
        border-bottom: 1px solid rgba(255,255,255,0.06);
        margin-bottom: 20px;
    }

        .sidebar-logo h2 {
            color: #fff;
            font-size: 1.1rem;
            font-weight: 800;
            margin: 0;
            letter-spacing: -0.5px;
            text-transform: uppercase;
        }

        .sidebar-logo span {
            color: #3b82f6;
        }

        .sidebar-logo p {
            color: #64748b;
            font-size: 0.72rem;
            margin: 4px 0 0 0;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

    .sidebar-section {
        padding: 0 15px;
        margin-bottom: 25px;
    }

    .sidebar-section-title {
        color: #475569;
        font-size: 0.65rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        padding: 0 10px;
        margin-bottom: 8px;
    }

    .sidebar-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 11px 12px;
        border-radius: 10px;
        color: #94a3b8;
        text-decoration: none;
        font-size: 0.88rem;
        font-weight: 500;
        transition: all 0.2s ease;
        margin-bottom: 3px;
        cursor: pointer;
        border: none;
        background: transparent;
        width: 100%;
    }

        .sidebar-item:hover {
            background: rgba(255,255,255,0.07);
            color: #fff;
        }

        .sidebar-item.active {
            background: linear-gradient(135deg, #1d4ed8, #3b82f6);
            color: #fff;
            box-shadow: 0 4px 15px rgba(59,130,246,0.3);
        }

        .sidebar-item i {
            font-size: 1rem;
            width: 20px;
            text-align: center;
        }

    .sidebar-bottom {
        margin-top: auto;
        padding: 20px 15px;
        border-top: 1px solid rgba(255,255,255,0.06);
    }

    .user-info {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px;
        border-radius: 10px;
        background: rgba(255,255,255,0.05);
        margin-bottom: 10px;
    }

    .user-avatar {
        width: 36px;
        height: 36px;
        border-radius: 10px;
        background: linear-gradient(135deg, #1d4ed8, #3b82f6);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: 700;
        font-size: 0.9rem;
        flex-shrink: 0;
    }

    .user-details {
        overflow: hidden;
    }

    .user-name {
        color: #e2e8f0;
        font-size: 0.82rem;
        font-weight: 600;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .user-role {
        color: #64748b;
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .btn-logout-sidebar {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 10px 12px;
        border-radius: 10px;
        color: #ef4444;
        background: rgba(239,68,68,0.08);
        border: 1px solid rgba(239,68,68,0.15);
        text-decoration: none;
        font-size: 0.82rem;
        font-weight: 600;
        transition: all 0.2s ease;
        width: 100%;
        justify-content: center;
    }

        .btn-logout-sidebar:hover {
            background: #ef4444;
            color: white;
        }

    .main-content {
        margin-left: 240px;
        flex: 1;
        padding: 30px;
        min-height: 100vh;
    }

    .topbar {
        display: flex;
        align-items: center;
        margin-bottom: 30px;
    }

    .topbar-title h1 {
        font-size: 1.6rem;
        font-weight: 800;
        color: #0f172a;
        margin: 0;
        letter-spacing: -0.5px;
    }

    .topbar-title p {
        color: #64748b;
        font-size: 0.85rem;
        margin: 4px 0 0 0;
    }

    .import-card {
        background: #fff;
        border-radius: 20px;
        border: 1px solid #f1f5f9;
        box-shadow: 0 2px 15px rgba(0,0,0,0.04);
        max-width: 900px;
        overflow: hidden;
    }

    .form-header {
        padding: 24px 28px;
        border-bottom: 1px solid #f1f5f9;
    }

        .form-header h2 {
            margin: 0;
            font-size: 1rem;
            font-weight: 700;
            color: #0f172a;
        }

        .form-header p {
            margin: 4px 0 0 0;
            color: #64748b;
            font-size: 0.85rem;
        }

    .form-body {
        padding: 28px;
    }

    .csv-info {
        background: #f8fafc;
        border-radius: 12px;
        padding: 16px 20px;
        margin-bottom: 24px;
        border: 1px solid #e2e8f0;
        display: flex;
        align-items: center;
        gap: 12px;
    }

        .csv-info i {
            color: #3b82f6;
            font-size: 1.1rem;
            flex-shrink: 0;
        }

        .csv-info span {
            font-size: 0.82rem;
            color: #64748b;
            font-weight: 600;
        }

        .csv-info code {
            color: #1d4ed8;
            font-weight: 700;
            font-size: 0.88rem;
        }

    .upload-box {
        border: 2px dashed #e2e8f0;
        border-radius: 16px;
        padding: 48px 20px;
        text-align: center;
        cursor: pointer;
        transition: all 0.2s;
        background: #fff;
        margin-bottom: 24px;
    }

        .upload-box:hover, .upload-box.dragover {
            border-color: #3b82f6;
            background: #eff6ff;
        }

        .upload-box i {
            font-size: 2.5rem;
            color: #3b82f6;
            margin-bottom: 12px;
            display: block;
        }

        .upload-box p {
            margin: 0;
            color: #64748b;
            font-size: 0.92rem;
        }

    .file-name {
        margin-top: 8px;
        font-weight: 700;
        color: #0f172a;
        font-size: 0.88rem;
    }

    input[type="file"] {
        display: none;
    }

    .form-footer {
        padding: 20px 28px;
        background: #f8fafc;
        border-top: 1px solid #f1f5f9;
        display: flex;
        justify-content: flex-end;
        gap: 10px;
    }

    .btn-action {
        padding: 10px 22px;
        border-radius: 10px;
        font-weight: 700;
        font-size: 0.88rem;
        border: none;
        cursor: pointer;
        transition: all 0.2s ease;
        display: inline-flex;
        align-items: center;
        gap: 7px;
        text-decoration: none;
    }

    .btn-import {
        background: linear-gradient(135deg, #1d4ed8, #3b82f6);
        color: white;
        box-shadow: 0 4px 15px rgba(59,130,246,0.3);
    }

        .btn-import:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(59,130,246,0.4);
            color: white;
        }

    .btn-cancel {
        background: white;
        color: #64748b;
        border: 1px solid #e2e8f0;
    }

        .btn-cancel:hover {
            background: #f1f5f9;
            color: #334155;
        }

    /* RESULTADOS */
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 16px;
        margin-top: 28px;
    }

    .stat-item {
        padding: 20px;
        border-radius: 16px;
        text-align: center;
        border: 1px solid #f1f5f9;
        transition: all 0.3s ease;
    }

        .stat-item i {
            font-size: 1.5rem;
            margin-bottom: 8px;
            display: block;
        }

    .stat-num {
        font-size: 1.8rem;
        font-weight: 800;
        display: block;
    }

    .stat-label {
        font-size: 0.65rem;
        font-weight: 700;
        text-transform: uppercase;
        color: #64748b;
    }

    .s-new {
        background: #f0fdf4;
        border-color: #bbf7d0;
        color: #15803d;
    }

    .s-upd {
        background: #eff6ff;
        border-color: #bfdbfe;
        color: #1d4ed8;
    }

    .s-err {
        background: #fff1f2;
        border-color: #fecdd3;
        color: #be123c;
    }

    .error-log {
        margin-top: 24px;
        border-radius: 16px;
        border: 1px solid #fecdd3;
        overflow: hidden;
    }

    .error-log-header {
        background: #fff1f2;
        padding: 12px 20px;
        color: #be123c;
        font-weight: 700;
        font-size: 0.8rem;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .error-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.85rem;
    }

        .error-table th {
            text-align: left;
            padding: 12px 20px;
            background: #fff;
            border-bottom: 1px solid #fecdd3;
            color: #64748b;
            font-weight: 600;
            font-size: 0.72rem;
            text-transform: uppercase;
            letter-spacing: 0.8px;
        }

        .error-table td {
            padding: 12px 20px;
            border-bottom: 1px solid #fff1f2;
            background: #fff;
        }

    @@media (max-width: 1024px) {
        .sidebar {
            width: 70px;
        }

        .sidebar-logo h2, .sidebar-logo p, .sidebar-section-title, .sidebar-item span, .user-details, .btn-logout-sidebar span {
            display: none;
        }

        .sidebar-item {
            justify-content: center;
            padding: 12px;
        }

        .user-info {
            justify-content: center;
        }

        .btn-logout-sidebar {
            justify-content: center;
        }

        .main-content {
            margin-left: 70px;
        }
    }

    @@media (max-width: 768px) {
        .sidebar {
            display: none;
        }

        .main-content {
            margin-left: 0;
            padding: 20px 15px;
        }

        .stats-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="app-layout">
    <aside class="sidebar">
        <div class="sidebar-logo">
            <h2>Becarios<span>BD</span></h2>
            <p>Panel de Control</p>
        </div>
        <div class="sidebar-section">
            <p class="sidebar-section-title">Principal</p>
            <a class="sidebar-item" asp-page="/Productos/Inicio">
                <i class="bi bi-grid-1x2-fill"></i><span>Productos</span>
            </a>
            @if (User.IsInRole("Admin"))
            {
                <a class="sidebar-item" asp-page="/Usuarios/Index">
                    <i class="bi bi-people-fill"></i><span>Usuarios</span>
                </a>
                <a class="sidebar-item" asp-page="./Historial">
                    <i class="bi bi-clock-history"></i><span>Historial</span>
                </a>
            }
        </div>
        <div class="sidebar-section">
            <p class="sidebar-section-title">Herramientas</p>
            <a class="sidebar-item active" asp-page="Importar">
                <i class="bi bi-file-earmark-arrow-up"></i><span>Importar CSV</span>
            </a>
            <a class="sidebar-item" asp-page="Crear">
                <i class="bi bi-plus-circle"></i><span>Nuevo Producto</span>
            </a>
        </div>
        <div class="sidebar-bottom">
            <div class="user-info">
                <div class="user-avatar">@User.Identity.Name?.Substring(0, 1).ToUpper()</div>
                <div class="user-details">
                    <div class="user-name">@User.Identity.Name</div>
                    <div class="user-role">@(User.IsInRole("Admin") ? "Administrador" : "Usuario")</div>
                </div>
            </div>
            <a asp-page="/Index" asp-page-handler="Logout" class="btn-logout-sidebar">
                <i class="bi bi-box-arrow-right"></i><span>Cerrar Sesion</span>
            </a>
        </div>
    </aside>

    <main class="main-content">
        <div class="topbar">
            <div class="topbar-title">
                <h1>Importar Productos</h1>
                <p>Carga masiva de articulos desde un fichero CSV</p>
            </div>
        </div>

        <div class="import-card">
            <div class="form-header">
                <h2><i class="bi bi-file-earmark-arrow-up" style="color:#3b82f6;margin-right:8px;"></i>Importacion por CSV</h2>
                <p>El fichero debe seguir el formato indicado</p>
            </div>
            <div class="form-body">
                <div class="csv-info">
                    <i class="bi bi-info-circle-fill"></i>
                    <span>Formato requerido: <code>CodigoProducto, Nombre, Precio, Stock</code></span>
                </div>

                <form method="POST" enctype="multipart/form-data">
                    <div class="upload-box" id="dropZone" onclick="document.getElementById('fileInput').click()">
                        <i class="bi bi-filetype-csv"></i>
                        <p>Arrastra tu archivo CSV aqui o haz clic para seleccionar</p>
                        <p class="file-name" id="fileText">Ningun archivo seleccionado</p>
                    </div>
                    <input type="file" id="fileInput" name="FileCsv" accept=".csv" onchange="updateName(this)" />

                    <div class="form-footer" style="padding:0;background:none;border:0;margin-top:0;">
                        <a href="/Productos/Inicio" class="btn-action btn-cancel">
                            <i class="bi bi-x-lg"></i> Cancelar
                        </a>
                        <button type="submit" class="btn-action btn-import">
                            <i class="bi bi-cloud-arrow-up-fill"></i> Iniciar Importacion
                        </button>
                    </div>
                </form>

                @if (Model.MostrarResultados)
                {
                    <div class="stats-grid">
                        <div class="stat-item s-new">
                            <i class="bi bi-plus-circle"></i>
                            <span class="stat-num">@Model.Creados</span>
                            <span class="stat-label">Nuevos</span>
                        </div>
                        <div class="stat-item s-upd">
                            <i class="bi bi-arrow-repeat"></i>
                            <span class="stat-num">@Model.Actualizados</span>
                            <span class="stat-label">Actualizados</span>
                        </div>
                        <div class="stat-item s-err">
                            <i class="bi bi-exclamation-octagon"></i>
                            <span class="stat-num">@Model.Errores.Count</span>
                            <span class="stat-label">Errores</span>
                        </div>
                    </div>

                    @if (Model.Errores.Any())
                    {
                        <div class="error-log">
                            <div class="error-log-header">
                                <i class="bi bi-bug"></i> Registro de Errores
                            </div>
                            <table class="error-table">
                                <thead>
                                    <tr>
                                        <th>Linea</th>
                                        <th>Codigo</th>
                                        <th>Motivo</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var error in Model.Errores)
                                    {
                                        <tr>
                                            <td style="font-weight:700;color:#94a3b8;">#@error.Linea</td>
                                            <td style="font-weight:600;color:#0f172a;">@error.Codigo</td>
                                            <td style="color:#ef4444;font-weight:500;">@error.Motivo</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                }
            </div>
        </div>
    </main>
</div>

<script>
    function updateName(input) {
        document.getElementById('fileText').textContent = input.files[0]?.name || 'Ningun archivo seleccionado';
    }
    const dropZone = document.getElementById('dropZone');
    ['dragover', 'dragleave', 'drop'].forEach(evt => {
        dropZone.addEventListener(evt, e => {
            e.preventDefault();
            if (evt === 'dragover') dropZone.classList.add('dragover');
            else dropZone.classList.remove('dragover');
            if (evt === 'drop') {
                const file = e.dataTransfer.files[0];
                if (file?.name.endsWith('.csv')) {
                    const input = document.getElementById('fileInput');
                    input.files = e.dataTransfer.files;
                    updateName(input);
                }
            }
        });
    });
</script>