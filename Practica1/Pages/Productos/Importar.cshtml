@page
@model Practica1.Pages.Productos.ImportarModel
@{
    ViewData["Title"] = "Importar Productos - BecariosBD";
}

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

<style>
    nav, .navbar, footer, header:not(.header-home) {
        display: none !important;
    }

    body {
        margin: 0;
        padding: 0;
        width: 100%;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        font-family: 'Inter', sans-serif;
        background-color: #ffffff;
        color: #333;
    }

    .main-container {
        display: flex;
        justify-content: center;
        align-items: flex-start;
        width: 100%;
        padding: 60px 20px;
        box-sizing: border-box;
    }

    .glass-card {
        background: #ffffff;
        padding: 50px;
        border-radius: 40px;
        width: 100%;
        max-width: 1100px;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.08);
        border: 1px solid #f0f0f0;
    }

    h1 {
        margin: 0 0 10px 0;
        text-align: center;
        font-weight: 800;
        letter-spacing: -1.5px;
        font-size: 2.8rem;
        text-transform: uppercase;
        color: #1a1a1a;
    }

    .subtitle {
        text-align: center;
        color: #999;
        font-size: 0.95rem;
        margin-bottom: 40px;
    }

    /* ZONA DE SUBIDA */
    .upload-zone {
        border: 2px dashed #ddd;
        border-radius: 20px;
        padding: 50px;
        text-align: center;
        background: #fafafa;
        cursor: pointer;
        transition: all 0.3s ease;
        margin-bottom: 30px;
    }

        .upload-zone:hover, .upload-zone.dragover {
            border-color: #1565c0;
            background: #e3f2fd;
        }

        .upload-zone i {
            font-size: 3rem;
            color: #1565c0;
            margin-bottom: 15px;
            display: block;
        }

        .upload-zone p {
            margin: 0;
            color: #666;
            font-size: 1rem;
        }

        .upload-zone .file-name {
            margin-top: 10px;
            font-weight: 700;
            color: #1565c0;
            font-size: 0.95rem;
        }

    input[type="file"] {
        display: none;
    }

    /* BOTONES */
    .btn-container {
        display: flex;
        gap: 15px;
        margin-top: 10px;
    }

    .btn-cyber {
        flex: 2;
        padding: 18px;
        border-radius: 15px;
        border: none;
        background: #1565c0;
        color: white;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        cursor: pointer;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        text-decoration: none;
        box-shadow: 0 8px 20px rgba(21, 101, 192, 0.15);
        font-family: 'Inter', sans-serif;
        font-size: 1rem;
    }

        .btn-cyber:hover {
            transform: translateY(-3px);
            background: #1976d2;
            box-shadow: 0 12px 25px rgba(21, 101, 192, 0.25);
        }

    .btn-back {
        flex: 1;
        background: #ffffff;
        color: #666;
        border: 1px solid #ddd;
        box-shadow: none;
    }

        .btn-back:hover {
            background: #f5f5f5;
            color: #333;
            border-color: #ccc;
        }

    /* RESULTADOS */
    .results-container {
        margin-top: 40px;
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
        margin-bottom: 30px;
    }

    .stat-card {
        padding: 25px;
        border-radius: 20px;
        text-align: center;
        border: 1px solid #f0f0f0;
    }

        .stat-card i {
            font-size: 2rem;
            margin-bottom: 10px;
            display: block;
        }

        .stat-card .stat-number {
            font-size: 2.5rem;
            font-weight: 800;
            display: block;
        }

        .stat-card .stat-label {
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: #999;
            font-weight: 600;
        }

    .stat-created {
        background: #e8f5e9;
        border-color: #c8e6c9;
    }

        .stat-created i, .stat-created .stat-number {
            color: #2e7d32;
        }

    .stat-updated {
        background: #e3f2fd;
        border-color: #bbdefb;
    }

        .stat-updated i, .stat-updated .stat-number {
            color: #1565c0;
        }

    .stat-error {
        background: #fce4ec;
        border-color: #f8bbd0;
    }

        .stat-error i, .stat-error .stat-number {
            color: #c62828;
        }

    /* TABLA DE ERRORES */
    .error-table-container {
        border-radius: 20px;
        overflow: hidden;
        border: 1px solid #fecdd3;
    }

    .error-table-header {
        background: #fee2e2;
        padding: 15px 20px;
        font-weight: 700;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: #991b1b;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .error-table {
        width: 100%;
        border-collapse: collapse;
        background: #fff;
    }

        .error-table th {
            text-align: left;
            padding: 15px 20px;
            color: #991b1b;
            font-weight: 700;
            font-size: 0.8rem;
            text-transform: uppercase;
            border-bottom: 1px solid #fecdd3;
        }

        .error-table td {
            padding: 15px 20px;
            border-bottom: 1px solid #fff5f5;
            font-size: 0.9rem;
        }

        .error-table tr:last-child td {
            border-bottom: none;
        }

    /* FORMATO CSV */
    .csv-format {
        background: #f8f9fa;
        border-radius: 15px;
        padding: 20px 25px;
        margin-bottom: 30px;
        border: 1px solid #eee;
    }

        .csv-format h4 {
            margin: 0 0 10px 0;
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: #999;
            font-weight: 700;
        }

        .csv-format code {
            font-family: monospace;
            font-size: 0.9rem;
            color: #1565c0;
        }

    @@media (max-width: 600px) {
        .glass-card

    {
        padding: 25px 15px;
        border-radius: 20px;
    }

    .main-container {
        padding: 20px 10px;
    }

    .btn-container {
        flex-direction: column;
    }

    .btn-cyber, .btn-back {
        flex: unset;
        width: 100%;
    }

    .stats-grid {
        grid-template-columns: 1fr;
    }

    .upload-zone {
        padding: 30px 15px;
    }

    }
</style>

<div class="main-container">
    <div class="glass-card">
        <h1>Importar Productos</h1>
        <p class="subtitle">Sube un fichero CSV para importar productos masivamente a la base de datos</p>

        <!-- FORMATO ESPERADO -->
        <div class="csv-format">
            <h4><i class="bi bi-info-circle"></i> Formato esperado del CSV</h4>
            <code>CodigoProducto,Nombre,Precio,Stock</code><br>
            <code>PROD-001,Monitor 27",350.00,15</code><br>
            <code>PROD-002,Teclado mecánico,89.99,40</code>
        </div>

        <!-- FORMULARIO DE SUBIDA -->
        <form method="POST" enctype="multipart/form-data" id="formImportar">
            <div class="upload-zone" id="uploadZone" onclick="document.getElementById('fileCsv').click()">
                <i class="bi bi-file-earmark-arrow-up"></i>
                <p>Haz clic o arrastra aquí tu fichero <strong>.csv</strong></p>
                <p class="file-name" id="fileName">Ningún fichero seleccionado</p>
            </div>
            <input type="file" id="fileCsv" name="FileCsv" accept=".csv" onchange="mostrarNombre(this)" />

            <div class="btn-container">
                <button type="submit" class="btn-cyber">
                    <i class="bi bi-cloud-upload"></i> Importar Productos
                </button>
                <a asp-page="./Inicio" class="btn-cyber btn-back">
                    <i class="bi bi-arrow-left"></i> Volver
                </a>
            </div>
        </form>

        <!-- RESULTADOS (solo se muestran tras importar) -->
        @if (Model.MostrarResultados)
        {
            <div class="results-container">
                <div class="stats-grid">
                    <div class="stat-card stat-created">
                        <i class="bi bi-plus-circle-fill"></i>
                        <span class="stat-number">@Model.Creados</span>
                        <span class="stat-label">Productos Creados</span>
                    </div>
                    <div class="stat-card stat-updated">
                        <i class="bi bi-pencil-square"></i>
                        <span class="stat-number">@Model.Actualizados</span>
                        <span class="stat-label">Productos Actualizados</span>
                    </div>
                    <div class="stat-card stat-error">
                        <i class="bi bi-x-circle-fill"></i>
                        <span class="stat-number">@Model.Errores.Count</span>
                        <span class="stat-label">Errores</span>
                    </div>
                </div>

                @if (Model.Errores.Any())
                {
                    <div class="error-table-container">
                        <div class="error-table-header">
                            <i class="bi bi-exclamation-triangle-fill"></i>
                            Productos con errores
                        </div>
                        <table class="error-table">
                            <thead>
                                <tr>
                                    <th>Línea</th>
                                    <th>Código</th>
                                    <th>Nombre</th>
                                    <th>Motivo del error</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var error in Model.Errores)
                                {
                                    <tr>
                                        <td style="color: #999; font-weight: 700;">#@error.Linea</td>
                                        <td style="font-weight: 600;">@error.Codigo</td>
                                        <td>@error.Nombre</td>
                                        <td style="color: #c62828; font-weight: 600;">@error.Motivo</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        }
    </div>
</div>

<script>
    function mostrarNombre(input) {
        const fileName = input.files[0]?.name ?? 'Ningún fichero seleccionado';
        document.getElementById('fileName').textContent = fileName;
    }

    // Drag & Drop
    const uploadZone = document.getElementById('uploadZone');

    uploadZone.addEventListener('dragover', (e) => {
        e.preventDefault();
        uploadZone.classList.add('dragover');
    });

    uploadZone.addEventListener('dragleave', () => {
        uploadZone.classList.remove('dragover');
    });

    uploadZone.addEventListener('drop', (e) => {
        e.preventDefault();
        uploadZone.classList.remove('dragover');
        const file = e.dataTransfer.files[0];
        if (file && file.name.endsWith('.csv')) {
            const input = document.getElementById('fileCsv');
            const dt = new DataTransfer();
            dt.items.add(file);
            input.files = dt.files;
            document.getElementById('fileName').textContent = file.name;
        }
    });
</script>