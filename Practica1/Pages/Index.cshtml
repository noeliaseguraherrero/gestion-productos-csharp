@page
@model IndexModel
@{
    ViewData["Title"] = "Login - BecariosBD";
}

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">

<style>
    nav, .navbar, footer, header:not(.header-home) {
        display: none !important;
    }

    body {
        margin: 0;
        padding: 0;
        width: 100%;
        height: 100vh;
        display: flex;
        flex-direction: column;
        font-family: 'Inter', sans-serif;
        background-color: #ffffff;
        color: #333;
        overflow: hidden;
    }

    .main-container {
        display: flex;
        justify-content: center;
        align-items: center;
        width: 100%;
        height: 100vh;
    }

    .card-login {
        background: #ffffff;
        padding: 60px;
        border-radius: 40px;
        color: #333;
        width: 95%;
        max-width: 550px;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.08);
        border: 1px solid #f0f0f0;
    }

    h2 {
        margin: 0 0 45px 0;
        text-align: center;
        font-weight: 800;
        letter-spacing: -1.5px;
        font-size: 2.2rem;
        text-transform: uppercase;
        color: #1a1a1a;
    }

    .form-group {
        margin-bottom: 30px;
    }

    label {
        display: block;
        text-align: left;
        margin-bottom: 12px;
        font-size: 0.75rem;
        color: darkred;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 2px;
    }

    input {
        width: 100%;
        padding: 18px 25px;
        border-radius: 15px;
        border: 2px solid #eee;
        box-sizing: border-box;
        background-color: #fafafa;
        color: #333;
        font-size: 1rem;
        outline: none;
        transition: all 0.3s ease;
    }

        input:hover,
        input:focus {
            background-color: #ffffff;
            border-color: #1b5e20;
            box-shadow: 0 5px 15px rgba(27, 94, 32, 0.1);
        }

    button {
        width: 100%;
        padding: 18px;
        border-radius: 15px;
        border: none;
        background: #1b5e20;
        color: white;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 2px;
        cursor: pointer;
        transition: all 0.4s ease;
        margin-top: 20px;
        box-shadow: 0 8px 20px rgba(27, 94, 32, 0.15);
    }

        button:hover {
            transform: translateY(-2px);
            background: #2e7d32;
            box-shadow: 0 12px 25px rgba(27, 94, 32, 0.25);
        }

        button:active {
            transform: translateY(1px);
        }

    .error-span {
        color: #d32f2f;
        font-size: 0.85rem;
        display: block;
        margin-bottom: 15px;
        text-align: center;
        font-weight: 600;
    }

    /* PASSWORD ICON INSIDE INPUT */
    .password-container {
        position: relative;
        width: 100%;
    }

        .password-container input {
            padding-right: 55px;
        }

    .toggle-password {
        position: absolute;
        right: 18px;
        top: 50%;
        transform: translateY(-50%);
        background: transparent;
        border: none;
        cursor: pointer;
        font-size: 1.2rem;
        padding: 0;
        margin: 0;
        width: auto;
        box-shadow: none;
        color: #666;
    }

        .toggle-password:hover {
            background: transparent;
            transform: translateY(-50%);
            box-shadow: none;
            color: #1b5e20;
        }

    .forgot-link:hover {
        color: #1b5e20 !important;
    }
</style>

<div class="main-container">
    <div class="card-login">
        <h2>Iniciar Sesión</h2>

        <form method="post">
            <div class="form-group">
                <label>Usuario</label>
                <input type="text" asp-for="Input.Usuario" placeholder="Ej. admin_becario" />
            </div>

            <div class="form-group">
                <label>Contraseña</label>
                <div class="password-container">
                    <input type="password" id="password" asp-for="Input.Contrasena" placeholder="Contraseña" />
                    <button type="button" class="toggle-password" onclick="mostrarPassword()">
                        <i id="iconoPassword" class="bi bi-eye"></i>
                    </button>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <span class="error-span">@Model.ErrorMessage</span>
            }

            <button type="submit">Acceder al Sistema</button>

            <a href="/Password/ForgotPassword" class="forgot-link"
               style="color: #666; font-size: 0.78rem; font-weight: 700;
          text-transform: uppercase; letter-spacing: 1.5px;
          text-decoration: none; transition: color 0.3s;">
                ¿Olvidaste tu contraseña?
            </a>

        </form>
    </div>
</div>

<script>
    function mostrarPassword() {
        const input = document.getElementById("password");
        input.type = input.type === "password" ? "text" : "password";
    }
</script>
<script>
        function mostrarPassword() {
        const input = document.getElementById("password");
        const icono = document.getElementById("iconoPassword");

        if (input.type === "password") {
            input.type = "text";
            icono.classList.remove("bi-eye");
            icono.classList.add("bi-eye-slash");
        } else {
            input.type = "password";
            icono.classList.remove("bi-eye-slash");
            icono.classList.add("bi-eye");
        }
    }
</script>