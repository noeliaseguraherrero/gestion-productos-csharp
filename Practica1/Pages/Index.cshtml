@page
@model IndexModel
@{
    ViewData["Title"] = "Login - BecariosBD";
}

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

<style>
    nav, .navbar, footer, header:not(.header-home) {
        display: none !important;
    }

    *, *::before, *::after {
        box-sizing: border-box;
    }

    body {
        margin: 0;
        padding: 0;
        width: 100%;
        height: 100vh;
        font-family: 'Inter', sans-serif;
        background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }

    .login-wrapper {
        display: flex;
        width: 100%;
        max-width: 900px;
        min-height: 520px;
        border-radius: 28px;
        overflow: hidden;
        box-shadow: 0 40px 80px rgba(0,0,0,0.4);
        margin: 20px;
    }

    /* PANEL IZQUIERDO */
    .login-left {
        flex: 1;
        background: linear-gradient(135deg, #1d4ed8 0%, #3b82f6 100%);
        padding: 50px 40px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        position: relative;
        overflow: hidden;
    }

        .login-left::before {
            content: '';
            position: absolute;
            top: -60px;
            right: -60px;
            width: 220px;
            height: 220px;
            border-radius: 50%;
            background: rgba(255,255,255,0.07);
        }

        .login-left::after {
            content: '';
            position: absolute;
            bottom: -40px;
            left: -40px;
            width: 160px;
            height: 160px;
            border-radius: 50%;
            background: rgba(255,255,255,0.05);
        }

    .brand h1 {
        color: #fff;
        font-size: 1.8rem;
        font-weight: 800;
        margin: 0 0 8px 0;
        letter-spacing: -1px;
        text-transform: uppercase;
    }

    .brand span {
        color: rgba(255,255,255,0.6);
        font-size: 0.78rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 2px;
    }

    .left-info {
        position: relative;
        z-index: 1;
    }

        .left-info h2 {
            color: #fff;
            font-size: 1.5rem;
            font-weight: 700;
            margin: 0 0 12px 0;
            letter-spacing: -0.5px;
        }

        .left-info p {
            color: rgba(255,255,255,0.7);
            font-size: 0.88rem;
            line-height: 1.7;
            margin: 0;
        }

    .left-features {
        display: flex;
        flex-direction: column;
        gap: 10px;
        position: relative;
        z-index: 1;
    }

    .feature-item {
        display: flex;
        align-items: center;
        gap: 10px;
        color: rgba(255,255,255,0.85);
        font-size: 0.82rem;
        font-weight: 500;
    }

        .feature-item i {
            width: 28px;
            height: 28px;
            border-radius: 8px;
            background: rgba(255,255,255,0.15);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.85rem;
            flex-shrink: 0;
        }

    /* PANEL DERECHO */
    .login-right {
        width: 400px;
        background: #ffffff;
        padding: 50px 45px;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

        .login-right h3 {
            font-size: 1.4rem;
            font-weight: 800;
            color: #0f172a;
            margin: 0 0 6px 0;
            letter-spacing: -0.5px;
        }

        .login-right p {
            color: #94a3b8;
            font-size: 0.85rem;
            margin: 0 0 35px 0;
        }

    .form-group {
        margin-bottom: 20px;
    }

    label {
        display: block;
        margin-bottom: 8px;
        font-size: 0.72rem;
        color: #64748b;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1.5px;
    }

    input[type="text"],
    input[type="password"] {
        width: 100%;
        padding: 14px 18px;
        border-radius: 12px;
        border: 1.5px solid #e2e8f0;
        background: #f8fafc;
        color: #0f172a;
        font-size: 0.92rem;
        font-family: 'Inter', sans-serif;
        outline: none;
        transition: all 0.3s ease;
    }

        input[type="text"]:focus,
        input[type="password"]:focus {
            background: #fff;
            border-color: #3b82f6;
            box-shadow: 0 0 0 3px rgba(59,130,246,0.1);
        }

    .password-container {
        position: relative;
    }

        .password-container input {
            padding-right: 48px;
        }

    .toggle-password {
        position: absolute;
        right: 14px;
        top: 50%;
        transform: translateY(-50%);
        background: transparent;
        border: none;
        cursor: pointer;
        color: #94a3b8;
        font-size: 1rem;
        padding: 0;
        width: auto;
        margin: 0;
        box-shadow: none;
        transition: color 0.2s;
    }

        .toggle-password:hover {
            color: #3b82f6;
            background: transparent;
            transform: translateY(-50%);
            box-shadow: none;
        }

    .error-span {
        display: block;
        color: #be123c;
        font-size: 0.82rem;
        font-weight: 600;
        margin-bottom: 15px;
        padding: 10px 14px;
        background: #fff1f2;
        border: 1px solid #fecdd3;
        border-radius: 10px;
        text-align: center;
    }

    .btn-login {
        width: 100%;
        padding: 15px;
        border-radius: 12px;
        border: none;
        background: linear-gradient(135deg, #1d4ed8, #3b82f6);
        color: white;
        font-weight: 700;
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        cursor: pointer;
        transition: all 0.3s ease;
        margin-top: 10px;
        box-shadow: 0 4px 15px rgba(59,130,246,0.3);
        font-family: 'Inter', sans-serif;
    }

        .btn-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(59,130,246,0.4);
        }

        .btn-login:active {
            transform: translateY(0);
        }

    .forgot-link {
        display: block;
        text-align: center;
        margin-top: 18px;
        color: #94a3b8;
        font-size: 0.78rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1px;
        text-decoration: none;
        transition: color 0.2s;
    }

        .forgot-link:hover {
            color: #3b82f6;
        }

    /* ── RESPONSIVE LOGIN ── */
    /* Tablet */
    @@media (max-width: 1024px) and (min-width: 701px) {
        .login-wrapper {
            max-width: 720px;
        }

        .login-left {
            padding: 40px 28px;
        }

        .login-right {
            width: 330px;
            padding: 40px 28px;
        }
    }

    /* Móvil — layout vertical, recuadro visible */
    @@media (max-width: 700px) {
        body {
            align-items: center;
            padding: 24px 16px;
            height: auto;
            min-height: 100vh;
            overflow: auto;
        }

        .login-wrapper {
            flex-direction: column;
            max-width: 440px;
            width: 100%;
            min-height: unset;
            border-radius: 24px;
            margin: 0 auto;
        }

        .login-left {
            display: flex;
            flex-direction: column;
            gap: 10px;
            padding: 28px 28px 24px 28px;
            min-height: unset;
            border-radius: 0;
        }

        .brand h1 {
            font-size: 1.4rem;
        }

        .brand span {
            font-size: 0.72rem;
        }

        .left-info h2 {
            font-size: 1.1rem;
            margin-bottom: 6px;
        }

        .left-info p {
            font-size: 0.82rem;
        }
        /* Ocultar features en móvil */
        .left-features {
            display: none;
        }

        .login-right {
            width: 100%;
            padding: 30px 28px 32px 28px;
            border-radius: 0;
            min-height: unset;
        }

            .login-right h3 {
                font-size: 1.25rem;
            }

        input[type="text"],
        input[type="password"] {
            font-size: 1rem;
        }

        .btn-login {
            padding: 15px;
        }
    }

    @@media (max-width: 400px) {
        .login-left {
            padding: 24px 20px 20px 20px;
        }

        .login-right {
            padding: 24px 20px 28px 20px;
        }
    }
</style>

<div class="login-wrapper">

    <!-- IZQUIERDA -->
    <div class="login-left">
        <div class="brand">
            <h1>BecariosBD</h1>
            <span>Sistema de Gestion</span>
        </div>
        <div class="left-info">
            <h2>Control total de tu inventario</h2>
            <p>Gestiona productos, usuarios y accesos desde un unico panel centralizado.</p>
        </div>
        <div class="left-features">
            <div class="feature-item">
                <i class="bi bi-boxes"></i>
                Gestion de productos y stock
            </div>
            <div class="feature-item">
                <i class="bi bi-people"></i>
                Control de usuarios y roles
            </div>
            <div class="feature-item">
                <i class="bi bi-clock-history"></i>
                Historial de acciones
            </div>
            <div class="feature-item">
                <i class="bi bi-shield-check"></i>
                Acceso seguro y protegido
            </div>
        </div>
    </div>

    <!-- DERECHA -->
    <div class="login-right">
        <h3>Bienvenido</h3>
        <p>Introduce tus credenciales para acceder</p>

        <form method="post">
            <div class="form-group">
                <label>Usuario</label>
                <input type="text" asp-for="Input.Usuario" placeholder="Tu nombre de usuario" />
            </div>

            <div class="form-group">
                <label>Contraseña</label>
                <div class="password-container">
                    <input type="password" id="password" asp-for="Input.Contrasena" placeholder="Tu contraseña" />
                    <button type="button" class="toggle-password" onclick="togglePass()">
                        <i id="iconoPassword" class="bi bi-eye"></i>
                    </button>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <span class="error-span">
                    <i class="bi bi-exclamation-circle"></i> @Model.ErrorMessage
                </span>
            }

            <button type="submit" class="btn-login">
                <i class="bi bi-box-arrow-in-right"></i> Acceder al Sistema
            </button>

            <a href="/Password/ForgotPassword" class="forgot-link">
                Olvide mi contraseña
            </a>
        </form>
    </div>
</div>

<script>
    function togglePass() {
        const input = document.getElementById("password");
        const icono = document.getElementById("iconoPassword");
        if (input.type === "password") {
            input.type = "text";
            icono.classList.replace("bi-eye", "bi-eye-slash");
        } else {
            input.type = "password";
            icono.classList.replace("bi-eye-slash", "bi-eye");
        }
    }
</script>