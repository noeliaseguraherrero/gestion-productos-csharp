@page
@model Practica1.Pages.Password.ForgotPasswordModel
@{
    ViewData["Title"] = "Olvidé mi contraseña";
}

<div class="container mt-5" style="max-width: 450px;">
    <h2 class="mb-4">¿Olvidaste tu contraseña?</h2>

    @if (Model.Mensaje != null)
    {
        <div class="alert alert-info">@Model.Mensaje</div>
    }

    <form method="post">
        <div class="mb-3">
            <label for="email" class="form-label">Correo electrónico</label>
            <input type="email" class="form-control" id="email"
                   asp-for="Email" placeholder="tucorreo@ejemplo.com" required />
        </div>
        <button type="submit" class="btn btn-primary w-100">
            Enviar enlace de recuperación
        </button>
        <div class="mt-3 text-center">
            <a href="/">Volver al inicio de sesión</a>
        </div>
    </form>
</div>