@page
@model Practica1.Pages.Password.ResetPasswordModel
@{
    ViewData["Title"] = "Nueva Contraseña - BecariosBD";
}

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

<style>
    nav, .navbar, footer, header:not(.header-home) {
        display: none !important;
    }

    body {
        margin: 0;
        padding: 0;
        width: 100%;
        height: 100vh;
        display: flex;
        flex-direction: column;
        font-family: 'Inter', sans-serif;
        background-color: #ffffff;
        color: #333;
        overflow: hidden;
    }

    .main-container {
        display: flex;
        justify-content: center;
        align-items: center;
        width: 100%;
        height: 100vh;
    }

    .card-login {
        background: #ffffff;
        padding: 60px;
        border-radius: 40px;
        color: #333;
        width: 95%;
        max-width: 550px;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.08);
        border: 1px solid #f0f0f0;
    }

    h2 {
        margin: 0 0 10px 0;
        text-align: center;
        font-weight: 800;
        letter-spacing: -1.5px;
        font-size: 2rem;
        text-transform: uppercase;
        color: #1a1a1a;
    }

    .subtitulo {
        text-align: center;
        color: #999;
        font-size: 0.85rem;
        font-weight: 600;
        letter-spacing: 1px;
        margin-bottom: 40px;
        text-transform: uppercase;
    }

    .form-group {
        margin-bottom: 30px;
    }

    label {
        display: block;
        text-align: left;
        margin-bottom: 12px;
        font-size: 0.75rem;
        color: darkred;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 2px;
    }

    input[type="password"],
    input[type="text"] {
        width: 100%;
        padding: 18px 25px;
        border-radius: 15px;
        border: 2px solid #eee;
        box-sizing: border-box;
        background-color: #fafafa;
        color: #333;
        font-size: 1rem;
        outline: none;
        transition: all 0.3s ease;
    }

        input[type="password"]:hover,
        input[type="password"]:focus,
        input[type="text"]:hover,
        input[type="text"]:focus {
            background-color: #ffffff;
            border-color: #1976d2;
            box-shadow: 0 5px 15px rgba(25, 118, 210, 0.1);
        }

    .btn-submit {
        width: 100%;
        padding: 18px;
        border-radius: 15px;
        border: none;
        background: #1976d2;
        color: white;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 2px;
        cursor: pointer;
        transition: all 0.4s ease;
        margin-top: 10px;
        box-shadow: 0 8px 20px rgba(25, 118, 210, 0.15);
        font-size: 0.9rem;
    }

        .btn-submit:hover {
            transform: translateY(-2px);
            background: #1565c0;
            box-shadow: 0 12px 25px rgba(25, 118, 210, 0.25);
        }

    .alert-success {
        background-color: #dcfce7;
        color: #166534;
        border: 1px solid #bbf7d0;
        border-radius: 15px;
        padding: 16px 20px;
        text-align: center;
        font-weight: 700;
        font-size: 0.9rem;
        margin-bottom: 25px;
    }

    .alert-danger {
        background-color: #fee2e2;
        color: #991b1b;
        border: 1px solid #fecaca;
        border-radius: 15px;
        padding: 16px 20px;
        text-align: center;
        font-weight: 700;
        font-size: 0.9rem;
        margin-bottom: 25px;
    }

    .link-volver {
        display: block;
        text-align: center;
        margin-top: 25px;
        color: #666;
        font-size: 0.78rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        text-decoration: none;
        transition: color 0.3s;
    }

        .link-volver:hover {
            color: #1976d2;
        }

    .password-container {
        position: relative;
        width: 100%;
    }

        .password-container input {
            padding-right: 55px;
        }

    .toggle-password {
        position: absolute;
        right: 18px;
        top: 50%;
        transform: translateY(-50%);
        background: transparent;
        border: none;
        cursor: pointer;
        font-size: 1.2rem;
        padding: 0;
        margin: 0;
        width: auto;
        box-shadow: none;
        color: #666;
    }

        .toggle-password:hover {
            background: transparent;
            transform: translateY(-50%);
            box-shadow: none;
            color: #1976d2;
        }
</style>

<div class="main-container">
    <div class="card-login">

        <h2>Nueva Contrasena</h2>
        <p class="subtitulo">Establece tu nueva contrasena de acceso</p>

        @if (Model.TokenInvalido)
        {
            <div class="alert-danger">
                El enlace no es valido o ha caducado.
            </div>
            <a href="/Password/ForgotPassword" class="link-volver">
                Solicitar un nuevo enlace
            </a>
        }
        else if (Model.Exito)
        {
            <div class="alert-success">
                Contrasena actualizada correctamente. Revisa tu correo.
            </div>
            <a href="/" class="link-volver">Volver al inicio de sesion</a>
        }
        else
        {
            <form method="post">
                <input type="hidden" asp-for="Token" />

                <div class="form-group">
                    <label>Nueva Contrasena</label>
                    <div class="password-container">
                        <input type="password" id="nuevaPass" asp-for="NuevaPassword"
                               placeholder="Minimo 6 caracteres" required minlength="6" />
                        <button type="button" class="toggle-password" onclick="togglePassword('nuevaPass', 'iconoNueva')">
                            <i id="iconoNueva" class="bi bi-eye"></i>
                        </button>
                    </div>
                </div>

                <div class="form-group">
                    <label>Confirmar Contrasena</label>
                    <div class="password-container">
                        <input type="password" id="confirmarPass" asp-for="ConfirmarPassword"
                               placeholder="Repite la contrasena" required minlength="6" />
                        <button type="button" class="toggle-password" onclick="togglePassword('confirmarPass', 'iconoConfirmar')">
                            <i id="iconoConfirmar" class="bi bi-eye"></i>
                        </button>
                    </div>
                </div>

                @if (Model.ErrorPassword != null)
                {
                    <div class="alert-danger">@Model.ErrorPassword</div>
                }

                <button type="submit" class="btn-submit">Guardar Contrasena</button>
            </form>

            <a href="/" class="link-volver">Volver al inicio de sesion</a>
        }
    </div>
</div>

<script>
    function togglePassword(inputId, iconId) {
        const input = document.getElementById(inputId);
        const icono = document.getElementById(iconId);

        if (input.type === "password") {
            input.type = "text";
            icono.classList.remove("bi-eye");
            icono.classList.add("bi-eye-slash");
        } else {
            input.type = "password";
            icono.classList.remove("bi-eye-slash");
            icono.classList.add("bi-eye");
        }
    }
</script>