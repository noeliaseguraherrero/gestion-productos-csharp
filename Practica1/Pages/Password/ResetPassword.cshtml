@page
@model Practica1.Pages.Password.ResetPasswordModel
@{
    ViewData["Title"] = "Nueva contraseña";
}

<div class="container mt-5" style="max-width: 450px;">
    <h2 class="mb-4">Establece tu nueva contraseña</h2>

    @if (Model.TokenInvalido)
    {
        <div class="alert alert-danger">
            El enlace no es válido o ha caducado.
            <a href="/ForgotPassword">Solicitar uno nuevo</a>
        </div>
    }
    else if (Model.Exito)
    {
        <div class="alert alert-success">
            Contraseña actualizada correctamente.
            <a href="/">Iniciar sesión</a>
        </div>
    }
    else
    {
        <form method="post">
            <input type="hidden" asp-for="Token" />
            <div class="mb-3">
                <label class="form-label">Nueva contraseña</label>
                <input type="password" class="form-control"
                       asp-for="NuevaPassword" required minlength="6" />
            </div>
            <div class="mb-3">
                <label class="form-label">Confirmar contraseña</label>
                <input type="password" class="form-control"
                       asp-for="ConfirmarPassword" required minlength="6" />
            </div>
            @if (Model.ErrorPassword != null)
            {
                <div class="alert alert-danger">@Model.ErrorPassword</div>
            }
            <button type="submit" class="btn btn-success w-100">
                Guardar nueva contraseña
            </button>
        </form>
    }
</div>