@page
@model Practica1.Pages.Password.ResetPasswordModel
@{
    ViewData["Title"] = "Nueva Contraseña - BecariosBD";
}

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">

<style>
    nav, .navbar, footer, header:not(.header-home) {
        display: none !important;
    }

    body {
        margin: 0;
        padding: 0;
        width: 100%;
        height: 100vh;
        display: flex;
        flex-direction: column;
        font-family: 'Inter', sans-serif;
        background-color: #ffffff;
        color: #333;
        overflow: hidden;
    }

    .main-container {
        display: flex;
        justify-content: center;
        align-items: center;
        width: 100%;
        height: 100vh;
    }

    .card-login {
        background: #ffffff;
        padding: 60px;
        border-radius: 40px;
        color: #333;
        width: 95%;
        max-width: 550px;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.08);
        border: 1px solid #f0f0f0;
    }

    h2 {
        margin: 0 0 45px 0;
        text-align: center;
        font-weight: 800;
        letter-spacing: -1.5px;
        font-size: 2.2rem;
        text-transform: uppercase;
        color: #1a1a1a;
    }

    .form-group {
        margin-bottom: 30px;
    }

    label {
        display: block;
        text-align: left;
        margin-bottom: 12px;
        font-size: 0.75rem;
        color: darkred;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 2px;
    }

    input[type="password"] {
        width: 100%;
        padding: 18px 25px;
        border-radius: 15px;
        border: 2px solid #eee;
        box-sizing: border-box;
        background-color: #fafafa;
        color: #333;
        font-size: 1rem;
        outline: none;
        transition: all 0.3s ease;
    }

        input[type="password"]:hover,
        input[type="password"]:focus {
            background-color: #ffffff;
            border-color: #1b5e20;
            box-shadow: 0 5px 15px rgba(27, 94, 32, 0.1);
        }

    .btn-submit {
        width: 100%;
        padding: 18px;
        border-radius: 15px;
        border: none;
        background: #1b5e20;
        color: white;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 2px;
        cursor: pointer;
        transition: all 0.4s ease;
        margin-top: 20px;
        box-shadow: 0 8px 20px rgba(27, 94, 32, 0.15);
    }

        .btn-submit:hover {
            transform: translateY(-2px);
            background: #2e7d32;
            box-shadow: 0 12px 25px rgba(27, 94, 32, 0.25);
        }

    .alert-box {
        padding: 16px 20px;
        border-radius: 15px;
        text-align: center;
        font-weight: 600;
        font-size: 0.9rem;
        margin-bottom: 25px;
    }

    .alert-danger {
        background-color: #fee2e2;
        color: #991b1b;
        border: 1px solid #fecaca;
    }

    .alert-success {
        background-color: #dcfce7;
        color: #166534;
        border: 1px solid #bbf7d0;
    }

    .link-volver {
        display: block;
        text-align: center;
        margin-top: 20px;
        color: #666;
        font-size: 0.78rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        text-decoration: none;
        transition: color 0.3s;
    }

        .link-volver:hover {
            color: #1b5e20;
        }
</style>

<div class="main-container">
    <div class="card-login">
        <h2>Nueva Contraseña</h2>

        @if (Model.TokenInvalido)
        {
            <div class="alert-box alert-danger">
                El enlace no es válido o ha caducado.
            </div>
            <a href="/Password/ForgotPassword" class="link-volver">
                Solicitar un nuevo enlace
            </a>
        }
        else if (Model.Exito)
        {
            <div class="alert-box alert-success">
                Contraseña actualizada correctamente.
            </div>
            <a href="/" class="link-volver">Volver al inicio de sesión</a>
        }
        else
        {
            <form method="post">
                <input type="hidden" asp-for="Token" />

                <div class="form-group">
                    <label>Nueva Contraseña</label>
                    <input type="password" asp-for="NuevaPassword"
                           placeholder="Mínimo 6 caracteres" required minlength="6" />
                </div>

                <div class="form-group">
                    <label>Confirmar Contraseña</label>
                    <input type="password" asp-for="ConfirmarPassword"
                           placeholder="Repite la contraseña" required minlength="6" />
                </div>

                @if (Model.ErrorPassword != null)
                {
                    <div class="alert-box alert-danger">@Model.ErrorPassword</div>
                }

                <button type="submit" class="btn-submit">Guardar Contraseña</button>
            </form>

            <a href="/" class="link-volver">Volver al inicio de sesión</a>
        }
    </div>
</div>