@page
@model Practica1.Pages.Password.ResetPasswordModel
@{
    ViewData["Title"] = "Nueva contrasena - BecariosBD";
}

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

<style>
    nav, .navbar, footer, header:not(.header-home) {
        display: none !important;
    }

    *, *::before, *::after {
        box-sizing: border-box;
    }

    body {
        margin: 0;
        padding: 0;
        width: 100%;
        height: 100vh;
        font-family: 'Inter', sans-serif;
        background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }

    .login-wrapper {
        display: flex;
        width: 100%;
        max-width: 900px;
        min-height: 520px;
        border-radius: 28px;
        overflow: hidden;
        box-shadow: 0 40px 80px rgba(0,0,0,0.4);
        margin: 20px;
    }

    .login-left {
        flex: 1;
        background: linear-gradient(135deg, #1d4ed8 0%, #3b82f6 100%);
        padding: 50px 40px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        position: relative;
        overflow: hidden;
    }

        .login-left::before {
            content: '';
            position: absolute;
            top: -60px;
            right: -60px;
            width: 220px;
            height: 220px;
            border-radius: 50%;
            background: rgba(255,255,255,0.07);
        }

        .login-left::after {
            content: '';
            position: absolute;
            bottom: -40px;
            left: -40px;
            width: 160px;
            height: 160px;
            border-radius: 50%;
            background: rgba(255,255,255,0.05);
        }

    .brand h1 {
        color: #fff;
        font-size: 1.8rem;
        font-weight: 800;
        margin: 0 0 8px 0;
        letter-spacing: -1px;
        text-transform: uppercase;
    }

    .brand span {
        color: rgba(255,255,255,0.6);
        font-size: 0.78rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 2px;
    }

    .left-info {
        position: relative;
        z-index: 1;
    }

        .left-info h2 {
            color: #fff;
            font-size: 1.5rem;
            font-weight: 700;
            margin: 0 0 12px 0;
            letter-spacing: -0.5px;
        }

        .left-info p {
            color: rgba(255,255,255,0.7);
            font-size: 0.88rem;
            line-height: 1.7;
            margin: 0;
        }

    .password-tips {
        display: flex;
        flex-direction: column;
        gap: 10px;
        position: relative;
        z-index: 1;
    }

    .tip-item {
        display: flex;
        align-items: center;
        gap: 10px;
        color: rgba(255,255,255,0.85);
        font-size: 0.82rem;
    }

        .tip-item i {
            width: 26px;
            height: 26px;
            border-radius: 8px;
            background: rgba(255,255,255,0.15);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.8rem;
            flex-shrink: 0;
        }

    .login-right {
        width: 400px;
        background: #ffffff;
        padding: 50px 45px;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

        .login-right h3 {
            font-size: 1.4rem;
            font-weight: 800;
            color: #0f172a;
            margin: 0 0 6px 0;
            letter-spacing: -0.5px;
        }

        .login-right p.subtitle {
            color: #94a3b8;
            font-size: 0.85rem;
            margin: 0 0 30px 0;
        }

    .form-group {
        margin-bottom: 20px;
    }

    label {
        display: block;
        margin-bottom: 8px;
        font-size: 0.72rem;
        color: #64748b;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1.5px;
    }

    input[type="password"],
    input[type="text"] {
        width: 100%;
        padding: 14px 18px;
        border-radius: 12px;
        border: 1.5px solid #e2e8f0;
        background: #f8fafc;
        color: #0f172a;
        font-size: 0.92rem;
        font-family: 'Inter', sans-serif;
        outline: none;
        transition: all 0.3s ease;
    }

        input[type="password"]:focus,
        input[type="text"]:focus {
            background: #fff;
            border-color: #3b82f6;
            box-shadow: 0 0 0 3px rgba(59,130,246,0.1);
        }

    .password-container {
        position: relative;
    }

        .password-container input {
            padding-right: 48px;
        }

    .toggle-password {
        position: absolute;
        right: 14px;
        top: 50%;
        transform: translateY(-50%);
        background: transparent;
        border: none;
        cursor: pointer;
        color: #94a3b8;
        font-size: 1rem;
        padding: 0;
        width: auto;
        margin: 0;
        box-shadow: none;
        transition: color 0.2s;
    }

        .toggle-password:hover {
            color: #3b82f6;
            background: transparent;
            transform: translateY(-50%);
            box-shadow: none;
        }

    .alert-success {
        background: #f0fdf4;
        color: #166534;
        border: 1px solid #bbf7d0;
        border-radius: 12px;
        padding: 14px 18px;
        font-size: 0.85rem;
        font-weight: 600;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .alert-danger {
        background: #fff1f2;
        color: #be123c;
        border: 1px solid #fecdd3;
        border-radius: 12px;
        padding: 14px 18px;
        font-size: 0.85rem;
        font-weight: 600;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .btn-submit {
        width: 100%;
        padding: 15px;
        border-radius: 12px;
        border: none;
        background: linear-gradient(135deg, #1d4ed8, #3b82f6);
        color: white;
        font-weight: 700;
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        cursor: pointer;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(59,130,246,0.3);
        font-family: 'Inter', sans-serif;
        margin-top: 5px;
    }

        .btn-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(59,130,246,0.4);
        }

    .link-volver {
        display: block;
        text-align: center;
        margin-top: 18px;
        color: #94a3b8;
        font-size: 0.78rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1px;
        text-decoration: none;
        transition: color 0.2s;
    }

        .link-volver:hover {
            color: #3b82f6;
        }

    @@media (max-width: 700px) {
        body {
            align-items: center;
            padding: 24px 16px;
            height: auto;
            min-height: 100vh;
            overflow: auto;
        }

        .login-wrapper {
            flex-direction: column;
            max-width: 440px;
            width: 100%;
            min-height: unset;
            border-radius: 24px;
            margin: 0 auto;
        }

        .login-left {
            display: flex;
            flex-direction: column;
            gap: 10px;
            padding: 28px 28px 24px;
            min-height: unset;
            border-radius: 0;
            justify-content: flex-start;
        }
        /* Ocultar solo los tips, mantener marca e info */
        .password-tips {
            display: none;
        }

        .brand h1 {
            font-size: 1.4rem;
        }

        .brand span {
            font-size: 0.72rem;
        }

        .left-info h2 {
            font-size: 1.1rem;
            margin-bottom: 6px;
        }

        .left-info p {
            font-size: 0.82rem;
        }

        .login-right {
            width: 100%;
            padding: 30px 28px 32px;
            border-radius: 0;
            min-height: unset;
            justify-content: flex-start;
        }

            .login-right h3 {
                font-size: 1.25rem;
            }

        input[type="password"],
        input[type="text"] {
            font-size: 1rem;
        }

        .btn-submit {
            padding: 15px;
        }
    }

    @@media (max-width: 400px) {
        .login-left,
        .login-right {
            padding-left: 20px;
            padding-right: 20px;
        }
    }

    @@media (max-width: 400px) {
        .login-right {
            padding-left: 20px;
            padding-right: 20px;
        }
    }
</style>

<div class="login-wrapper">

    <div class="login-left">
        <div class="brand">
            <h1>BecariosBD</h1>
            <span>Nueva Contraseña</span>
        </div>
        <div class="left-info">
            <h2>Elige una contraseña segura</h2>
            <p>Tu nueva contraseña protegera el acceso a tu cuenta. Asegurate de que sea unica y segura.</p>
        </div>
        <div class="password-tips">
            <div class="tip-item">
                <i class="bi bi-check-lg"></i> Minimo 6 caracteres
            </div>
            <div class="tip-item">
                <i class="bi bi-check-lg"></i> Combina letras y numeros
            </div>
            <div class="tip-item">
                <i class="bi bi-check-lg"></i> Evita contraseñas repetidas
            </div>
            <div class="tip-item">
                <i class="bi bi-shield-lock"></i> El enlace caduca en 1 hora
            </div>
        </div>
    </div>

    <div class="login-right">
        <h3>Nueva Contrasena</h3>
        <p class="subtitle">Establece tu nueva contraseña de acceso</p>

        @if (Model.TokenInvalido)
        {
            <div class="alert-danger">
                <i class="bi bi-exclamation-circle-fill"></i>
                El enlace no es valido o ha caducado.
            </div>
            <a href="/Password/ForgotPassword" class="link-volver">
                Solicitar un nuevo enlace
            </a>
        }
        else if (Model.Exito)
        {
            <div class="alert-success">
                <i class="bi bi-check-circle-fill"></i>
                Contraseña actualizada correctamente.
            </div>
            <a href="/" class="link-volver">
                <i class="bi bi-arrow-left"></i> Volver al inicio de sesión
            </a>
        }
        else
        {
            <form method="post">
                <input type="hidden" asp-for="Token" />

                <div class="form-group">
                    <label>Nueva Contraseña</label>
                    <div class="password-container">
                        <input type="password" id="nuevaPass" asp-for="NuevaPassword"
                               placeholder="Minimo 6 caracteres" required minlength="6" />
                        <button type="button" class="toggle-password"
                                onclick="togglePassword('nuevaPass','iconoNueva')">
                            <i id="iconoNueva" class="bi bi-eye"></i>
                        </button>
                    </div>
                </div>

                <div class="form-group">
                    <label>Confirmar Contraseña</label>
                    <div class="password-container">
                        <input type="password" id="confirmarPass" asp-for="ConfirmarPassword"
                               placeholder="Repite la contraseña" required minlength="6" />
                        <button type="button" class="toggle-password"
                                onclick="togglePassword('confirmarPass','iconoConfirmar')">
                            <i id="iconoConfirmar" class="bi bi-eye"></i>
                        </button>
                    </div>
                </div>

                @if (Model.ErrorPassword != null)
                {
                    <div class="alert-danger">
                        <i class="bi bi-exclamation-circle-fill"></i>
                        @Model.ErrorPassword
                    </div>
                }

                <button type="submit" class="btn-submit">
                    <i class="bi bi-lock-fill"></i> Guardar Contraseña
                </button>
            </form>

            <a href="/" class="link-volver">
                <i class="bi bi-arrow-left"></i> Volver al inicio de sesion
            </a>
        }
    </div>
</div>

<script>
    function togglePassword(inputId, iconId) {
        const input = document.getElementById(inputId);
        const icono = document.getElementById(iconId);
        if (input.type === "password") {
            input.type = "text";
            icono.classList.replace("bi-eye", "bi-eye-slash");
        } else {
            input.type = "password";
            icono.classList.replace("bi-eye-slash", "bi-eye");
        }
    }
</script>