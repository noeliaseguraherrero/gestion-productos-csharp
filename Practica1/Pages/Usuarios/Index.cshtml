@page
@model Practica1.Pages.Usuarios.IndexModel
@{
    ViewData["Title"] = "Usuarios - BecariosBD";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<style>
    nav, .navbar, footer, header:not(.header-home) {
        display: none !important;
    }

    *, *::before, *::after {
        box-sizing: border-box;
    }

    body {
        margin: 0;
        padding: 0;
        width: 100%;
        min-height: 100vh;
        font-family: 'Inter', sans-serif;
        background: linear-gradient(135deg, #f0f4f8 0%, #e8edf2 100%);
        color: #1a1a2e;
    }

    .app-layout {
        display: flex;
        min-height: 100vh;
    }

    .sidebar {
        width: 240px;
        min-height: 100vh;
        background: #0f172a;
        display: flex;
        flex-direction: column;
        padding: 30px 0;
        position: fixed;
        top: 0;
        left: 0;
        z-index: 200;
        transition: transform 0.3s ease;
    }

    .sidebar-logo {
        padding: 0 25px 30px 25px;
        border-bottom: 1px solid rgba(255,255,255,0.06);
        margin-bottom: 20px;
    }

        .sidebar-logo h2 {
            color: #fff;
            font-size: 1.1rem;
            font-weight: 800;
            margin: 0;
            letter-spacing: -0.5px;
            text-transform: uppercase;
        }

        .sidebar-logo span {
            color: #3b82f6;
        }

        .sidebar-logo p {
            color: #64748b;
            font-size: 0.72rem;
            margin: 4px 0 0 0;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

    .sidebar-section {
        padding: 0 15px;
        margin-bottom: 25px;
    }

    .sidebar-section-title {
        color: #475569;
        font-size: 0.65rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        padding: 0 10px;
        margin-bottom: 8px;
    }

    .sidebar-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 11px 12px;
        border-radius: 10px;
        color: #94a3b8;
        text-decoration: none;
        font-size: 0.88rem;
        font-weight: 500;
        transition: all 0.2s ease;
        margin-bottom: 3px;
        border: none;
        background: transparent;
        width: 100%;
    }

        .sidebar-item:hover {
            background: rgba(255,255,255,0.07);
            color: #fff;
        }

        .sidebar-item.active {
            background: linear-gradient(135deg, #1d4ed8, #3b82f6);
            color: #fff;
            box-shadow: 0 4px 15px rgba(59,130,246,0.3);
        }

        .sidebar-item i {
            font-size: 1rem;
            width: 20px;
            text-align: center;
        }

    .sidebar-bottom {
        margin-top: auto;
        padding: 20px 15px;
        border-top: 1px solid rgba(255,255,255,0.06);
    }

    .user-info {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px;
        border-radius: 10px;
        background: rgba(255,255,255,0.05);
        margin-bottom: 10px;
    }

    .user-avatar {
        width: 36px;
        height: 36px;
        border-radius: 10px;
        background: linear-gradient(135deg, #1d4ed8, #3b82f6);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: 700;
        font-size: 0.9rem;
        flex-shrink: 0;
    }

    .user-details {
        overflow: hidden;
    }

    .user-name {
        color: #e2e8f0;
        font-size: 0.82rem;
        font-weight: 600;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .user-role {
        color: #64748b;
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .btn-logout-sidebar {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 10px 12px;
        border-radius: 10px;
        color: #ef4444;
        background: rgba(239,68,68,0.08);
        border: 1px solid rgba(239,68,68,0.15);
        text-decoration: none;
        font-size: 0.82rem;
        font-weight: 600;
        transition: all 0.2s ease;
        width: 100%;
        justify-content: center;
    }

        .btn-logout-sidebar:hover {
            background: #ef4444;
            color: white;
        }

    .main-content {
        margin-left: 240px;
        flex: 1;
        padding: 30px;
        min-height: 100vh;
    }

    .topbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
    }

    .topbar-title h1 {
        font-size: 1.6rem;
        font-weight: 800;
        color: #0f172a;
        margin: 0;
        letter-spacing: -0.5px;
    }

    .topbar-title p {
        color: #64748b;
        font-size: 0.85rem;
        margin: 4px 0 0 0;
    }

    .btn-new {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 12px 22px;
        border-radius: 12px;
        background: linear-gradient(135deg, #1d4ed8, #3b82f6);
        color: white;
        font-weight: 700;
        font-size: 0.88rem;
        border: none;
        cursor: pointer;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(59,130,246,0.3);
        font-family: 'Inter', sans-serif;
    }

        .btn-new:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(59,130,246,0.4);
            color: white;
        }

    .table-card {
        background: #fff;
        border-radius: 20px;
        border: 1px solid #f1f5f9;
        box-shadow: 0 2px 15px rgba(0,0,0,0.04);
        overflow: hidden;
    }

    .table-card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 22px 25px;
        border-bottom: 1px solid #f1f5f9;
    }

    .table-card-title {
        font-size: 1rem;
        font-weight: 700;
        color: #0f172a;
        margin: 0;
    }

    .table-wrapper {
        overflow-x: auto;
    }

    .custom-table {
        width: 100%;
        border-collapse: collapse;
        min-width: 580px;
    }

        .custom-table th {
            padding: 13px 20px;
            text-align: left;
            font-size: 0.72rem;
            font-weight: 700;
            color: #94a3b8;
            text-transform: uppercase;
            letter-spacing: 0.8px;
            background: #f8fafc;
            border-bottom: 1px solid #f1f5f9;
        }

        .custom-table td {
            padding: 16px 20px;
            border-bottom: 1px solid #f8fafc;
            font-size: 0.88rem;
            vertical-align: middle;
        }

        .custom-table tbody tr {
            transition: background 0.15s ease;
        }

            .custom-table tbody tr:hover {
                background: #f8fafc;
            }

            .custom-table tbody tr:last-child td {
                border-bottom: none;
            }

    .role-badge {
        padding: 4px 12px;
        border-radius: 20px;
        font-weight: 700;
        font-size: 0.72rem;
        text-transform: uppercase;
        display: inline-flex;
        align-items: center;
        gap: 5px;
    }

    .role-admin {
        background: #eff6ff;
        color: #1d4ed8;
        border: 1px solid #bfdbfe;
    }

    .role-user {
        background: #f8fafc;
        color: #475569;
        border: 1px solid #e2e8f0;
    }

    .btn-status {
        border: none;
        padding: 5px 12px;
        border-radius: 20px;
        font-weight: 700;
        font-size: 0.72rem;
        text-transform: uppercase;
        display: inline-flex;
        align-items: center;
        gap: 5px;
        cursor: pointer;
        transition: all 0.2s;
        font-family: 'Inter', sans-serif;
    }

    .btn-active {
        background: #dcfce7;
        color: #166534;
        border: 1px solid #bbf7d0;
    }

        .btn-active:hover {
            background: #166534;
            color: white;
        }

    .btn-inactive {
        background: #fee2e2;
        color: #991b1b;
        border: 1px solid #fecaca;
    }

        .btn-inactive:hover {
            background: #991b1b;
            color: white;
        }

    .btn-circle {
        width: 34px;
        height: 34px;
        border-radius: 9px;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 1px solid #e2e8f0;
        background: white;
        transition: all 0.2s;
        color: #64748b;
        cursor: pointer;
        font-family: 'Inter', sans-serif;
    }

    .btn-edit-user:hover {
        border-color: #3b82f6;
        color: #3b82f6;
        background: #eff6ff;
    }

    .btn-delete-user:hover {
        border-color: #ef4444;
        color: #ef4444;
        background: #fff1f2;
    }

    .modal-content {
        border-radius: 20px;
        border: none;
        overflow: hidden;
    }

    .modal-header {
        background: #f8fafc;
        border-bottom: 1px solid #f1f5f9;
        padding: 20px 25px;
    }

    .modal-title {
        font-weight: 800;
        color: #0f172a;
        font-size: 1rem;
    }

    .modal-body {
        padding: 25px;
    }

    .modal-label {
        display: block;
        font-size: 0.72rem;
        font-weight: 700;
        color: #94a3b8;
        text-transform: uppercase;
        letter-spacing: 0.8px;
        margin-bottom: 8px;
    }

    .form-control, .form-select {
        border-radius: 10px;
        border: 1px solid #e2e8f0;
        padding: 10px 14px;
        font-size: 0.88rem;
        font-family: 'Inter', sans-serif;
        transition: all 0.2s;
    }

        .form-control:focus, .form-select:focus {
            border-color: #3b82f6;
            box-shadow: 0 0 0 3px rgba(59,130,246,0.1);
        }

    .btn-save-modal {
        background: linear-gradient(135deg, #1d4ed8, #3b82f6);
        color: white;
        border-radius: 10px;
        font-weight: 700;
        border: none;
        padding: 12px;
        width: 100%;
        transition: all 0.2s;
        font-family: 'Inter', sans-serif;
        font-size: 0.88rem;
        cursor: pointer;
    }

        .btn-save-modal:hover {
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(59,130,246,0.3);
        }

    /* MOBILE TOPBAR */
    .mobile-topbar {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        height: 62px;
        background: rgba(240,244,248,0.85);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid rgba(255,255,255,0.6);
        z-index: 250;
        align-items: center;
        padding: 0 16px;
    }

    .menu-toggle {
        width: 42px;
        height: 42px;
        border-radius: 12px;
        background: #0f172a;
        border: none;
        color: white;
        font-size: 1.1rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 15px rgba(0,0,0,0.2);
        flex-shrink: 0;
    }

    .sidebar-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.5);
        z-index: 150;
    }

    /* TABLET */
    @@media (max-width: 1024px) {
        .sidebar {
            width: 70px;
        }

        .sidebar-logo h2, .sidebar-logo p, .sidebar-section-title,
        .sidebar-item span, .user-details, .btn-logout-sidebar span {
            display: none;
        }

        .sidebar-item {
            justify-content: center;
            padding: 12px;
        }

        .user-info {
            justify-content: center;
        }

        .btn-logout-sidebar {
            justify-content: center;
        }

        .main-content {
            margin-left: 70px;
        }

        .topbar {
            flex-wrap: wrap;
            gap: 12px;
        }
    }

    /* MOVIL */
    @@media (max-width: 767px) {
        .mobile-topbar {
            display: flex;
        }

        .sidebar {
            width: 240px;
            transform: translateX(-100%);
        }

            .sidebar.open {
                transform: translateX(0);
            }

        .sidebar-logo h2, .sidebar-logo p, .sidebar-section-title,
        .sidebar-item span, .user-details, .btn-logout-sidebar span {
            display: block !important;
        }

        .sidebar-item {
            justify-content: flex-start !important;
            padding: 11px 12px !important;
        }

        .user-info {
            justify-content: flex-start !important;
        }

        .sidebar-overlay.open {
            display: block;
        }

        .main-content {
            margin-left: 0 !important;
            width: 100% !important;
            padding: 16px;
            padding-top: 78px;
        }

        .topbar {
            flex-direction: column;
            align-items: flex-start;
            gap: 12px;
        }

        .topbar-title h1 {
            font-size: 1.3rem;
        }

        .btn-new {
            width: 100%;
            justify-content: center;
        }

        .table-wrapper {
            display: none;
        }

        .user-cards {
            display: flex;
            flex-direction: column;
            gap: 10px;
            padding: 15px;
        }

        .user-card {
            background: #fff;
            border: 1px solid #f1f5f9;
            border-radius: 14px;
            padding: 16px;
        }

        .user-card-top {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 12px;
            padding-bottom: 12px;
            border-bottom: 1px solid #f1f5f9;
        }

        .user-card-avatar {
            width: 38px;
            height: 38px;
            border-radius: 10px;
            background: #f1f5f9;
            color: #475569;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 0.9rem;
            flex-shrink: 0;
        }

        .user-card-name {
            font-weight: 700;
            color: #0f172a;
            font-size: 0.95rem;
        }

        .user-card-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 6px 0;
            font-size: 0.85rem;
            border-bottom: 1px solid #f8fafc;
            gap: 10px;
        }

            .user-card-row:last-of-type {
                border-bottom: none;
            }

        .user-card-label {
            font-size: 0.68rem;
            color: #94a3b8;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.8px;
            flex-shrink: 0;
        }

        .user-card-actions {
            display: flex;
            gap: 8px;
            justify-content: flex-end;
            margin-top: 12px;
            flex-wrap: wrap;
        }
    }

    @@media (min-width: 768px) {
        .user-cards {
            display: none;
        }
    }
</style>

<div class="mobile-topbar">
    <button class="menu-toggle" id="menuToggle">
        <i class="bi bi-list" id="menuIcon"></i>
    </button>
</div>
<div class="sidebar-overlay" id="sidebarOverlay"></div>

<div class="app-layout">
    <aside class="sidebar">
        <div class="sidebar-logo">
            <h2>Becarios<span>BD</span></h2>
            <p>Panel de Control</p>
        </div>
        <div class="sidebar-section">
            <p class="sidebar-section-title">Principal</p>
            <a class="sidebar-item" asp-page="/Productos/Inicio">
                <i class="bi bi-grid-1x2-fill"></i><span>Productos</span>
            </a>
            @if (User.IsInRole("Admin"))
            {
                <a class="sidebar-item active" asp-page="/Usuarios/Index">
                    <i class="bi bi-people-fill"></i><span>Usuarios</span>
                </a>
                <a class="sidebar-item" asp-page="/Productos/Historial">
                    <i class="bi bi-clock-history"></i><span>Historial</span>
                </a>
            }
        </div>
        <div class="sidebar-section">
            <p class="sidebar-section-title">Herramientas</p>
            <a class="sidebar-item" asp-page="/Productos/Importar">
                <i class="bi bi-file-earmark-arrow-up"></i><span>Importar CSV</span>
            </a>
            <a class="sidebar-item" asp-page="/Productos/Crear">
                <i class="bi bi-plus-circle"></i><span>Nuevo Producto</span>
            </a>
        </div>
        <div class="sidebar-bottom">
            <div class="user-info">
                <div class="user-avatar">@User.Identity.Name?.Substring(0, 1).ToUpper()</div>
                <div class="user-details">
                    <div class="user-name">@User.Identity.Name</div>
                    <div class="user-role">@(User.IsInRole("Admin") ? "Administrador" : "Usuario")</div>
                </div>
            </div>
            <a asp-page="/Index" asp-page-handler="Logout" class="btn-logout-sidebar">
                <i class="bi bi-box-arrow-right"></i><span>Cerrar Sesion</span>
            </a>
        </div>
    </aside>

    <main class="main-content">
        <div class="topbar">
            <div class="topbar-title">
                <h1>Control de Usuarios</h1>
                <p>Gestion de accesos y permisos del sistema</p>
            </div>
            <button class="btn-new" data-bs-toggle="modal" data-bs-target="#modalCrear">
                <i class="bi bi-person-plus-fill"></i> Agregar Usuario
            </button>
        </div>

        <div class="table-card">
            <div class="table-card-header">
                <h3 class="table-card-title">
                    <i class="bi bi-people-fill" style="color:#3b82f6;margin-right:8px;"></i>Lista de Usuarios
                </h3>
            </div>
            <div class="table-wrapper">
                <table class="custom-table">
                    <thead>
                        <tr>
                            <th>Usuario</th>
                            <th>Rol</th>
                            <th>Estado</th>
                            <th style="text-align:right;">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var usuario in Model.Usuarios)
                        {
                            <tr>
                                <td>
                                    <div style="display:flex;align-items:center;gap:10px;">
                                        <div style="width:32px;height:32px;border-radius:9px;background:#f1f5f9;color:#475569;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:0.82rem;flex-shrink:0;">
                                            @usuario.Nombre.Substring(0, 1).ToUpper()
                                        </div>
                                        <span style="font-weight:600;color:#0f172a;">@usuario.Nombre</span>
                                    </div>
                                </td>
                                <td>
                                    <span class="role-badge @(usuario.Rol == "Admin" ? "role-admin" : "role-user")">
                                        <i class="bi @(usuario.Rol == "Admin" ? "bi-shield-check" : "bi-person")"></i>
                                        @usuario.Rol.ToUpper()
                                    </span>
                                </td>
                                <td>
                                    <form method="post" asp-page-handler="CambiarEstado" asp-route-id="@usuario.Id" style="display:inline;">
                                        <button class="btn-status @(usuario.Activo ? "btn-active" : "btn-inactive")">
                                            <i class="bi @(usuario.Activo ? "bi-check-circle-fill" : "bi-x-circle-fill")"></i>
                                            @(usuario.Activo ? "Activo" : "Inactivo")
                                        </button>
                                    </form>
                                </td>
                                <td>
                                    <div style="display:flex;gap:8px;justify-content:flex-end;">
                                        <button class="btn-circle btn-edit-user" data-bs-toggle="modal" data-bs-target="#modalEditar-@usuario.Id">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        @if (User.Identity.Name != usuario.Nombre)
                                        {
                                            <form method="post" asp-page-handler="Eliminar" asp-route-id="@usuario.Id" onsubmit="return confirm('¿Eliminar este usuario?')" style="display:inline;">
                                                <button class="btn-circle btn-delete-user">
                                                    <i class="bi bi-trash3"></i>
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>

                        }
                    </tbody>
                </table>
            </div>

            <div class="user-cards">
                @foreach (var usuario in Model.Usuarios)
                {
                    <div class="user-card">
                        <div class="user-card-top">
                            <div class="user-card-avatar">@usuario.Nombre.Substring(0, 1).ToUpper()</div>
                            <div>
                                <div class="user-card-name">@usuario.Nombre</div>
                                <span class="role-badge @(usuario.Rol == "Admin" ? "role-admin" : "role-user")" style="margin-top:4px;display:inline-flex;">
                                    <i class="bi @(usuario.Rol == "Admin" ? "bi-shield-check" : "bi-person")"></i>
                                    @usuario.Rol.ToUpper()
                                </span>
                            </div>
                        </div>
                        <div class="user-card-row">
                            <span class="user-card-label">Estado</span>
                            <form method="post" asp-page-handler="CambiarEstado" asp-route-id="@usuario.Id" style="display:inline;">
                                <button class="btn-status @(usuario.Activo ? "btn-active" : "btn-inactive")">
                                    <i class="bi @(usuario.Activo ? "bi-check-circle-fill" : "bi-x-circle-fill")"></i>
                                    @(usuario.Activo ? "Activo" : "Inactivo")
                                </button>
                            </form>
                        </div>
                        <div class="user-card-actions">
                            <button class="btn-circle btn-edit-user" data-bs-toggle="modal" data-bs-target="#modalEditar-@usuario.Id">
                                <i class="bi bi-pencil"></i>
                            </button>
                            @if (User.Identity.Name != usuario.Nombre)
                            {
                                <form method="post" asp-page-handler="Eliminar" asp-route-id="@usuario.Id" onsubmit="return confirm('¿Eliminar este usuario?')" style="display:inline;">
                                    <button class="btn-circle btn-delete-user">
                                        <i class="bi bi-trash3"></i>
                                    </button>
                                </form>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    </main>
</div>

<div class="modal fade" id="modalCrear" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form method="post" asp-page-handler="Crear">
                <div class="modal-header">
                    <h5 class="modal-title">Nuevo Usuario</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="modal-label">Nombre de Usuario</label>
                        <input type="text" asp-for="NuevoUsuario.Nombre" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label class="modal-label">Contraseña</label>
                        <input type="password" asp-for="NuevoUsuario.Contraseña" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label class="modal-label">Rol</label>
                        <select asp-for="NuevoUsuario.Rol" class="form-select">
                            <option value="Usuario">Usuario</option>
                            <option value="Admin">Administrador</option>
                        </select>
                    </div>
                    <button type="submit" class="btn-save-modal mt-2">Crear Usuario</button>
                </div>
            </form>
        </div>
    </div>
</div>
@foreach (var usuario in Model.Usuarios)
{
    <div class="modal fade" id="modalEditar-@usuario.Id" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <form method="post" asp-page-handler="Editar" asp-route-id="@usuario.Id">
                    <div class="modal-header">
                        <h5 class="modal-title">Editar: @usuario.Nombre</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="modal-label">Rol</label>
                            <select name="nuevoRol" class="form-select">
                                <option value="Usuario" selected="@(usuario.Rol == "Usuario")">Usuario</option>
                                <option value="Admin" selected="@(usuario.Rol == "Admin")">Administrador</option>
                            </select>
                        </div>
                        <button type="submit" class="btn-save-modal mt-2">Guardar Cambios</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}


<script>
    document.addEventListener("DOMContentLoaded", function () {
        var mensaje = '@TempData["Mensaje"]';
        var tipo = '@TempData["Tipo"]';
        if (mensaje && mensaje !== '') {
            const Toast = Swal.mixin({ toast: true, position: 'top-end', showConfirmButton: false, timer: 2500, timerProgressBar: true });
            Toast.fire({ icon: tipo || 'info', title: mensaje });
        }
    });
</script>
<script>
    document.addEventListener('DOMContentLoaded', function () {
        const menuToggle   = document.getElementById('menuToggle');
        const menuIcon     = document.getElementById('menuIcon');
        const sidebar      = document.querySelector('.sidebar');
        const overlay      = document.getElementById('sidebarOverlay');
        const mobileTopbar = document.querySelector('.mobile-topbar');

        function openSidebar() {
            sidebar.classList.add('open');
            overlay.classList.add('open');
            document.body.style.overflow = 'hidden';
            menuIcon.classList.replace('bi-list', 'bi-x-lg');
            mobileTopbar.style.display = 'none';
        }
        function closeSidebar() {
            sidebar.classList.remove('open');
            overlay.classList.remove('open');
            document.body.style.overflow = '';
            menuIcon.classList.replace('bi-x-lg', 'bi-list');
            mobileTopbar.style.display = 'flex';
        }

        menuToggle?.addEventListener('click', () => {
            sidebar.classList.contains('open') ? closeSidebar() : openSidebar();
        });
        overlay?.addEventListener('click', closeSidebar);
        sidebar?.querySelectorAll('.sidebar-item').forEach(item => {
            item.addEventListener('click', () => { if (window.innerWidth < 768) closeSidebar(); });
        });
        document.addEventListener('keydown', e => { if (e.key === 'Escape') closeSidebar(); });
    });
</script>